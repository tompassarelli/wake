{
  description = "wake-app — generated by wake";

  inputs = {
    nixpkgs.url = "github:NixOS/nixpkgs/nixos-unstable";
  };

  outputs = { self, nixpkgs }:
    let
      system = "x86_64-linux";
      pkgs = import nixpkgs { inherit system; };
    in {
      packages.${system}.default = pkgs.stdenv.mkDerivation {
        pname = "wake-app";
        version = "0.1.0";
        src = ./.;
        nativeBuildInputs = [ pkgs.nodejs_22 ];
        installPhase = ''
          mkdir -p $out/share/wake-app $out/bin
          cp -r . $out/share/wake-app/

          cat > $out/bin/wake-app-server <<'SCRIPT'
          #!/usr/bin/env bash
          exec ${pkgs.nodejs_22}/bin/node $out/share/wake-app/server.js "$@"
          SCRIPT
          chmod +x $out/bin/wake-app-server

          cat > $out/bin/wake-app-migrate <<'SCRIPT'
          #!/usr/bin/env bash
          echo 'SQLite: schema applied on server start'
          SCRIPT
          chmod +x $out/bin/wake-app-migrate
        '';
      };

      nixosModules.default = { config, lib, pkgs, ... }:
        let
          cfg = config.services.wake_app;
        in {
          options.services.wake_app = {
            enable = lib.mkEnableOption "wake-app server";
            port = lib.mkOption {
              type = lib.types.port;
              default = 3000;
              description = "Port for the wake-app server";
            };
            domain = lib.mkOption {
              type = lib.types.str;
              default = "localhost";
              description = "Domain for nginx vhost";
            };
          };

          config = lib.mkIf cfg.enable {
            systemd.services.wake_app = {
              description = "wake-app server";
              wantedBy = [ "multi-user.target" ];
              after = [ "network.target" ];
              environment = {
                PORT = toString cfg.port;
              };
              serviceConfig = {
                ExecStart = "${self.packages.${system}.default}/bin/wake-app-server";
                DynamicUser = true;
                StateDirectory = "wake_app";
                WorkingDirectory = "${self.packages.${system}.default}/share/wake-app";
                Restart = "on-failure";
                RestartSec = 5;
              };
            };

            services.nginx = {
              enable = true;
              virtualHosts.${cfg.domain} = {
                locations."/" = {
                  proxyPass = "http://127.0.0.1:${toString cfg.port}";
                  proxyWebsockets = true;
                };
              };
            };

            networking.firewall.allowedTCPPorts = [ 80 443 ];
          };
        };

      devShells.${system}.default = pkgs.mkShell {
        packages = with pkgs; [ nodejs_22 ];
      };
    };
}
