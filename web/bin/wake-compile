#!/usr/bin/env bash
# wake-compile: compile .bjs sources and wire them as ES modules.
# Produces dist/ with importable modules + CLI entry point.
#
# Usage:
#   bin/wake-compile                        # compile all modules
#   bin/wake-compile demo/crm-v2.wake      # compile + build one app (JS)
#   bin/wake-compile --sql demo/crm-v2.wake  # emit SQL DDL
#   bin/wake-compile --server demo/crm-v2.wake # emit server.js
#   bin/wake-compile --mcp demo/crm-v2.wake    # emit MCP tool catalog (JSON)
#   bin/wake-compile --all demo/crm-v2.wake out/ # full stack

set -euo pipefail

wake_root="$(cd "$(dirname "$0")/.." && pwd)"
compiler="$wake_root/compiler"

BEAGLE_COMPILER="${BEAGLE_COMPILER:-$HOME/code/beagle/self-host/dist/compiler.cjs}"
BEAGLE_BUILD="${BEAGLE_BUILD:-$HOME/code/beagle/bin/beagle-build}"
if [[ -f "$BEAGLE_COMPILER" ]] && command -v bun >/dev/null 2>&1; then
  compile() { bun run "$BEAGLE_COMPILER" "$1"; }
  echo "using beagle-bun compiler" >&2
elif [[ -x "$BEAGLE_BUILD" ]]; then
  # No self-host compiler.cjs yet; use beagle-build (racket with beagle-lib
  # collections linked via _beagle-racket). It can't write /dev/stdout, so
  # round-trip through a temp file.
  compile() { local o; o="$(mktemp)"; "$BEAGLE_BUILD" "$1" "$o" >/dev/null 2>&1; cat "$o"; rm -f "$o"; }
  echo "using beagle-build compiler" >&2
else
  if [[ -z "${IN_NIX_SHELL:-}" ]] && [[ -f "$wake_root/flake.nix" ]]; then
    exec nix develop "$wake_root" --command "$0" "$@"
  fi
  compile() { racket "$1"; }
  echo "using racket compiler" >&2
fi
dist="$compiler/dist"

mkdir -p "$dist"

# Step 1: compile each .bjs → .js
modules=(sexpr ir graph reader ui js-ast emit-sql emit-server emit-test emit-nix emit-claims-ir emit-mcp codegen)
for mod in "${modules[@]}"; do
  echo "compiling $mod.bjs..." >&2
  compile "$compiler/$mod.bjs" > "$dist/$mod.js.tmp"
done

# Step 2: add exports to modules that have none

# sexpr.js — export parse_all
{
  cat "$dist/sexpr.js.tmp"
  echo ""
  echo "export { parse_all };"
} > "$dist/sexpr.js"

# ir.js — export all constructors
{
  cat "$dist/ir.js.tmp"
  echo ""
  grep -oP '(?<=^function )\w+' "$dist/ir.js.tmp" | \
    paste -sd, | \
    sed 's/^/export { /; s/$/ };/'
} > "$dist/ir.js"

# graph.js — fix imports, add export
{
  sed "s|from './wake/ir.js';|from './ir.js';|" \
    "$dist/graph.js.tmp"
  echo ""
  echo "export { check_program, strip_colon, capitalize, titlecase, GField, GEntity, FkEdge, StateMachine, CheckedGraph };"
} > "$dist/graph.js"

# ui.js — export expand_list_detail
{
  cat "$dist/ui.js.tmp"
  echo ""
  echo "export { expand_list_detail, UiFieldInfo, UiRelated, UiForm, UiGraph, UiComponent, UiBind, UiQuery, UiEach, UiWhen, UiAction, UiElement, UiText, UiStore, UiState };"
} > "$dist/ui.js"

# js-ast.js — export all functions
{
  cat "$dist/js-ast.js.tmp"
  echo ""
  grep -oP '(?<=^function )\w+' "$dist/js-ast.js.tmp" | \
    paste -sd, | \
    sed 's/^/export { /; s/$/ };/'
} > "$dist/js-ast.js"

# emit-sql.js — fix imports, add export
{
  sed "s|from './wake/graph.js';|from './graph.js';|" \
    "$dist/emit-sql.js.tmp"
  echo ""
  echo "export { gen_sql, gen_migration };"
} > "$dist/emit-sql.js"

# emit-server.js — fix imports, add export
{
  sed "s|from './wake/graph.js';|from './graph.js';|; s|from './wake/js-ast.js';|from './js-ast.js';|" \
    "$dist/emit-server.js.tmp"
  echo ""
  echo "export { gen_server };"
} > "$dist/emit-server.js"

# reader.js — fix imports, add export
{
  sed "s|from './wake/sexpr.js';|from './sexpr.js';|; s|from './wake/ir.js';|from './ir.js';|" \
    "$dist/reader.js.tmp"
  echo ""
  echo "export { parse_program };"
} > "$dist/reader.js"

# emit-test.js — fix imports, add export
{
  sed "s|from './wake/graph.js';|from './graph.js';|" \
    "$dist/emit-test.js.tmp"
  echo ""
  echo "export { gen_tests };"
} > "$dist/emit-test.js"

# emit-nix.js — fix imports, add export
{
  sed "s|from './wake/graph.js';|from './graph.js';|" \
    "$dist/emit-nix.js.tmp"
  echo ""
  echo "export { gen_nix };"
} > "$dist/emit-nix.js"

# codegen.js — fix imports, add export
{
  sed "s|from './wake/ir.js';|from './ir.js';|; s|from './wake/graph.js';|from './graph.js';|; s|from './wake/ui.js';|from './ui.js';|" \
    "$dist/codegen.js.tmp"
  echo ""
  echo "export { gen_program_bang };"
} > "$dist/codegen.js"

# emit-claims-ir.js — fix imports, add export
{
  sed "s|from './wake/graph.js';|from './graph.js';|" \
    "$dist/emit-claims-ir.js.tmp"
  echo ""
  echo "export { gen_claims };"
} > "$dist/emit-claims-ir.js"

# emit-mcp.js — fix imports, add export
{
  sed "s|from './wake/graph.js';|from './graph.js';|" \
    "$dist/emit-mcp.js.tmp"
  echo ""
  echo "export { gen_mcp };"
} > "$dist/emit-mcp.js"

# Cleanup temp files
rm -f "$dist"/*.tmp

echo "modules built in $dist/" >&2

# Step 3: emit target(s)
emit_js() {
  local src="$1" out="$2"
  node --input-type=module -e "
import { readFileSync } from 'fs';
import { parse_program } from '$dist/reader.js';
import { gen_program_bang } from '$dist/codegen.js';
const prog = parse_program(readFileSync('$src', 'utf-8'));
process.stdout.write(gen_program_bang(prog));
" > "$out"
}

emit_sql() {
  local src="$1" out="$2"
  node --input-type=module -e "
import { readFileSync } from 'fs';
import { parse_program } from '$dist/reader.js';
import { gen_sql } from '$dist/emit-sql.js';
const prog = parse_program(readFileSync('$src', 'utf-8'));
process.stdout.write(gen_sql(prog));
" > "$out"
}

emit_server() {
  local src="$1" out="$2"
  node --input-type=module -e "
import { readFileSync } from 'fs';
import { parse_program } from '$dist/reader.js';
import { gen_server } from '$dist/emit-server.js';
const prog = parse_program(readFileSync('$src', 'utf-8'));
process.stdout.write(gen_server(prog));
" > "$out"
}

emit_test() {
  local src="$1" out="$2"
  node --input-type=module -e "
import { readFileSync } from 'fs';
import { parse_program } from '$dist/reader.js';
import { gen_tests } from '$dist/emit-test.js';
const prog = parse_program(readFileSync('$src', 'utf-8'));
process.stdout.write(gen_tests(prog));
" > "$out"
}

emit_nix() {
  local src="$1" out="$2"
  node --input-type=module -e "
import { readFileSync } from 'fs';
import { parse_program } from '$dist/reader.js';
import { gen_nix } from '$dist/emit-nix.js';
const prog = parse_program(readFileSync('$src', 'utf-8'));
process.stdout.write(gen_nix(prog));
" > "$out"
}

emit_claims() {
  local src="$1" out="$2"
  node --input-type=module -e "
import { readFileSync } from 'fs';
import { parse_program } from '$dist/reader.js';
import { gen_claims } from '$dist/emit-claims-ir.js';
const prog = parse_program(readFileSync('$src', 'utf-8'));
process.stdout.write(gen_claims(prog));
" > "$out"
}

emit_mcp() {
  local src="$1" out="$2"
  node --input-type=module -e "
import { readFileSync } from 'fs';
import { parse_program } from '$dist/reader.js';
import { gen_mcp } from '$dist/emit-mcp.js';
const prog = parse_program(readFileSync('$src', 'utf-8'));
process.stdout.write(gen_mcp(prog));
" > "$out"
}

if [[ $# -ge 1 && "$1" == "--all" ]]; then
  shift
  wake_file="$1"
  out_dir="${2:-.}"
  mkdir -p "$out_dir"
  emit_js "$wake_file" "$out_dir/app.js"
  emit_sql "$wake_file" "$out_dir/schema.sql"
  emit_server "$wake_file" "$out_dir/server.js"
  emit_test "$wake_file" "$out_dir/tests.js"
  emit_nix "$wake_file" "$out_dir/flake.nix"
  emit_claims "$wake_file" "$out_dir/app.claims"
  emit_mcp "$wake_file" "$out_dir/mcp.json"
  cp "$wake_root/public-js/index.html" "$out_dir/" 2>/dev/null || true
  cp "$wake_root/public-js/dist.css" "$out_dir/" 2>/dev/null || true
  "$wake_root/bin/wake-lint-output" "$out_dir/server.js" >&2
  "$wake_root/bin/wake-lint-output" "$out_dir/app.js" >&2
  echo "$wake_file -> $out_dir/ (app.js + schema.sql + server.js + tests.js + flake.nix)" >&2
elif [[ $# -ge 1 && "$1" == "--test" ]]; then
  shift; emit_test "$1" "${2:-/dev/stdout}"
  [[ "${2:-}" ]] && echo "$1 -> $2 (tests)" >&2
elif [[ $# -ge 1 && "$1" == "--sql" ]]; then
  shift; emit_sql "$1" "${2:-/dev/stdout}"
  [[ "${2:-}" ]] && echo "$1 -> $2 (sql)" >&2
elif [[ $# -ge 1 && "$1" == "--migrate" ]]; then
  shift
  old_file="$1"; new_file="$2"; out_file="${3:-/dev/stdout}"
  destructive="false"
  [[ "${4:-}" == "--destructive" ]] && destructive="true"
  node --input-type=module -e "
import { readFileSync } from 'fs';
import { parse_program } from '$dist/reader.js';
import { gen_migration } from '$dist/emit-sql.js';
const oldProg = parse_program(readFileSync('$old_file', 'utf-8'));
const newProg = parse_program(readFileSync('$new_file', 'utf-8'));
process.stdout.write(gen_migration(oldProg, newProg, $destructive));
" > "$out_file"
  [[ "$out_file" != "/dev/stdout" ]] && echo "$old_file -> $new_file -> $out_file (migration)" >&2
elif [[ $# -ge 1 && "$1" == "--nix" ]]; then
  shift; emit_nix "$1" "${2:-/dev/stdout}"
  [[ "${2:-}" ]] && echo "$1 -> $2 (nix)" >&2
elif [[ $# -ge 1 && "$1" == "--claims" ]]; then
  shift; emit_claims "$1" "${2:-/dev/stdout}"
  [[ "${2:-}" ]] && echo "$1 -> $2 (claims)" >&2
elif [[ $# -ge 1 && "$1" == "--mcp" ]]; then
  shift; emit_mcp "$1" "${2:-/dev/stdout}"
  [[ "${2:-}" ]] && echo "$1 -> $2 (mcp)" >&2
elif [[ $# -ge 1 && "$1" == "--server" ]]; then
  shift; emit_server "$1" "${2:-/dev/stdout}"
  [[ "${2:-}" ]] && "$wake_root/bin/wake-lint-output" "$2" >&2
  [[ "${2:-}" ]] && echo "$1 -> $2 (server)" >&2
elif [[ $# -ge 1 ]]; then
  emit_js "$1" "${2:-/dev/stdout}"
  [[ "${2:-}" ]] && echo "$1 -> $2" >&2
fi

# The trailing `[[ "${2:-}" ]] && echo ... >&2` in each branch above prints an advisory
# message only when an output PATH was given. With no $2 (the stdout-redirect case, e.g.
# `wake-compile app.wake > out.js` — exactly how CI invokes it), that bare test returns 1
# and, as the script's last statement, becomes the script's exit code under `set -e` —
# failing callers even though emit succeeded. Real emit failures abort earlier (set -e at
# the emit_* call), so reaching here means success. Make that explicit:
exit 0
