#lang beagle/js
(ns eddy.emit-test)
(require eddy.graph :as graph)
(require eddy.graph :refer [strip-colon capitalize])

;; Test emitter — entity graph → node:test integration suite.
;; Generates from the spec: CRUD, constraint violations, SQL injection,
;; full state machine coverage (BFS), FK cascade, named queries.
;; Each test is self-contained via factory functions.

(defn is-sm-field [(field :- Any) (state-machines :- Any)] :- Bool
  (some? (first (filterv (fn [sm] (= (.-state-type sm) (.-type field))) state-machines))))

;; --- BFS: compute setup chains to reach every state ---

(defn bfs-setup-chains [(transitions :- Any) (initial-kw :- String)] :- Any
  (let [initial (strip-colon initial-kw)]
    (loop [queue [initial]
           visited [initial]
           chains (assoc {} initial [])]
      (if (= (count queue) 0)
        chains
        (let [state (first queue)
              rest-queue (subvec queue 1)
              state-kw (str ":" state)
              targets (mapv strip-colon (or (get transitions state-kw) []))
              unvisited (filterv (fn [t] (not (.includes visited t))) targets)
              new-chains (reduce (fn [c t] (assoc c t (conj (get c state) t))) chains unvisited)
              new-visited (into visited unvisited)
              new-queue (into rest-queue unvisited)]
          (recur new-queue new-visited new-chains))))))

;; --- Preamble ---

(defn gen-preamble [(src-name :- String)] :- String
  (str
    "// Generated by eddy — semantic application compiler\n"
    "// Source: " src-name "\n"
    "// Integration tests derived from entity graph\n\n"
    #r#"
    import { describe, it, before, after } from 'node:test';
    import assert from 'node:assert/strict';
    import { spawn } from 'node:child_process';
    import { join } from 'node:path';
    import { fileURLToPath } from 'node:url';
    import { unlinkSync, existsSync } from 'node:fs';

    const __dirname = fileURLToPath(new URL('.', import.meta.url));
    const PORT = 19000 + Math.floor(Math.random() * 1000);
    const DB_PATH = join(__dirname, 'app.db');
    let _uid = 0;
    function uid(p) { return p + '_' + (++_uid); }

    async function api(method, path, body) {
      const opts = { method, headers: { 'Content-Type': 'application/json' } };
      if (body) opts.body = JSON.stringify(body);
      const res = await fetch(`http://localhost:${PORT}${path}`, opts);
      const data = await res.json().catch(() => null);
      return { status: res.status, data };
    }

    let serverProc;

    before(async () => {
      if (existsSync(DB_PATH)) unlinkSync(DB_PATH);
      serverProc = spawn('node', [join(__dirname, 'server.js')], {
        env: { ...process.env, PORT: String(PORT) },
        stdio: ['pipe', 'pipe', 'pipe']
      });
      await new Promise((resolve, reject) => {
        const timeout = setTimeout(() => reject(new Error('Server start timeout')), 5000);
        serverProc.stdout.on('data', (d) => {
          if (d.toString().includes('eddy server')) { clearTimeout(timeout); resolve(); }
        });
      });
    });

    after(() => {
      serverProc.kill();
      if (existsSync(DB_PATH)) unlinkSync(DB_PATH);
    });

    "#
    "\n\n"))

;; --- Factory functions: build + create per entity ---

(defn gen-build-fn [(entity :- Any) (state-machines :- Any)] :- String
  (let [name (.-name entity)
        cap (capitalize name)
        stored (.-stored-fields entity)
        fields (filterv (fn [f]
          (and (not (.-ref f))
               (not (is-sm-field f state-machines))))
          stored)
        defaults (.join (mapv (fn [f]
          (str "'" (.-name f) "': uid('" (.-name f) "')"))
          fields) ", ")]
    (str "function build" cap "(o = {}) { return { " defaults ", ...o }; }\n")))

(defn gen-create-fn [(entity :- Any) (state-machines :- Any) (all-entities :- Any)] :- String
  (let [name (.-name entity)
        cap (capitalize name)
        store-name (.-store-name entity)
        ref-fields (.-ref-fields entity)
        parent-setup (.join (mapv (fn [rf]
          (let [parent-name (.-name rf)
                parent-cap (capitalize parent-name)]
            (str "  if (!o['" parent-name "']) { const p = await create" parent-cap "(); o['" parent-name "'] = Number(p.eid); }\n")))
          ref-fields) "")]
    (str
      "async function create" cap "(overrides = {}) {\n"
      "  const o = build" cap "(overrides);\n"
      parent-setup
      "  const { data } = await api('POST', '/api/" store-name "', o);\n"
      "  return data;\n"
      "}\n")))

(defn gen-factories [(entities :- Any) (state-machines :- Any)] :- String
  (let [roots (filterv (fn [e] (= (count (.-ref-fields e)) 0)) entities)
        deps (filterv (fn [e] (> (count (.-ref-fields e)) 0)) entities)
        sorted (into roots deps)]
    (str
      (.join (mapv (fn [e] (gen-build-fn e state-machines)) sorted) "")
      (.join (mapv (fn [e] (gen-create-fn e state-machines sorted)) sorted) "")
      "\n")))

;; --- CRUD tests (self-contained) ---

(defn gen-crud-tests [(entity :- Any) (state-machines :- Any)] :- String
  (let [name (.-name entity)
        cap (capitalize name)
        store-name (.-store-name entity)
        update-field (first (filterv (fn [f]
          (and (not (.-ref f))
               (not (.-derived f))
               (not (is-sm-field f state-machines))))
          (.-stored-fields entity)))]
    (str
      "describe('" name " CRUD', () => {\n"
      "  it('creates via POST', async () => {\n"
      "    const e = await create" cap "();\n"
      "    assert.ok(e.eid);\n"
      "  });\n\n"
      "  it('lists via GET', async () => {\n"
      "    await create" cap "();\n"
      "    const { status, data } = await api('GET', '/api/" store-name "');\n"
      "    assert.equal(status, 200);\n"
      "    assert.ok(Array.isArray(data));\n"
      "  });\n\n"
      "  it('gets by id', async () => {\n"
      "    const e = await create" cap "();\n"
      "    const { status, data } = await api('GET', `/api/" store-name "/${e.eid}`);\n"
      "    assert.equal(status, 200);\n"
      "    assert.equal(Number(data.eid), Number(e.eid));\n"
      "  });\n\n"
      (if (nil? update-field) ""
        (str
          "  it('updates via PUT', async () => {\n"
          "    const e = await create" cap "();\n"
          "    const { status, data } = await api('PUT', `/api/" store-name "/${e.eid}`, { '" (.-name update-field) "': 'updated' });\n"
          "    assert.equal(status, 200);\n"
          "    assert.equal(data['" (.-name update-field) "'], 'updated');\n"
          "  });\n\n"))
      "  it('returns 404 for missing', async () => {\n"
      "    const { status } = await api('GET', '/api/" store-name "/99999');\n"
      "    assert.equal(status, 404);\n"
      "  });\n\n"
      "  it('deletes and verifies gone', async () => {\n"
      "    const e = await create" cap "();\n"
      "    const { status } = await api('DELETE', `/api/" store-name "/${e.eid}`);\n"
      "    assert.equal(status, 200);\n"
      "    const { status: s2 } = await api('GET', `/api/" store-name "/${e.eid}`);\n"
      "    assert.equal(s2, 404);\n"
      "  });\n"
      "});\n\n")))

;; --- Constraint + boundary tests ---

(defn gen-constraint-tests [(entity :- Any) (state-machines :- Any) (all-entities :- Any)] :- String
  (let [name (.-name entity)
        cap (capitalize name)
        store-name (.-store-name entity)
        unique-fields (.-unique-fields entity)
        ref-fields (.-ref-fields entity)
        sm (first (filterv (fn [m] (= (.-entity m) name)) state-machines))

        injectable (first (filterv (fn [f]
          (and (not (.-ref f))
               (not (.-derived f))
               (not (is-sm-field f state-machines))))
          (.-stored-fields entity)))

        unique-tests (.join (mapv (fn [uf]
          (let [fname (.-name uf)]
            (str
              "  it('rejects duplicate " fname "', async () => {\n"
              "    const dup = uid('dup');\n"
              "    await create" cap "({ '" fname "': dup });\n"
              "    const { status } = await api('POST', '/api/" store-name "', build" cap "({ '" fname "': dup }));\n"
              "    assert.ok(status >= 400);\n"
              "  });\n\n")))
          unique-fields) "")

        injection-test (if (nil? injectable) ""
          (str
            "  it('survives SQL injection in " (.-name injectable) "', async () => {\n"
            "    const e = await create" cap "({ '" (.-name injectable) "': \"'; DROP TABLE " name "; --\" });\n"
            "    assert.ok(e.eid);\n"
            "    const { data } = await api('GET', '/api/" store-name "');\n"
            "    assert.ok(Array.isArray(data));\n"
            "  });\n\n"))

        bad-ref-tests (.join (mapv (fn [rf]
          (let [fname (.-name rf)]
            (str
              "  it('rejects invalid " fname " ref', async () => {\n"
              "    const { status } = await api('POST', '/api/" store-name "', build" cap "({ '" fname "': 99999 }));\n"
              "    assert.ok(status >= 400);\n"
              "  });\n\n")))
          ref-fields) "")

        bogus-state-test (if (nil? sm) ""
          (let [field (.-field sm)]
            (str
              "  it('rejects bogus " field " value', async () => {\n"
              "    const e = await create" cap "();\n"
              "    const { status } = await api('PUT', `/api/" store-name "/${e.eid}`, { " field ": 'NONEXISTENT' });\n"
              "    assert.equal(status, 400);\n"
              "  });\n\n")))

        unknown-field-test (str
          "  it('ignores unknown fields in PUT', async () => {\n"
          "    const e = await create" cap "();\n"
          "    const { status, data } = await api('PUT', `/api/" store-name "/${e.eid}`, { __hack__: 'x' });\n"
          "    assert.equal(status, 400);\n"
          "  });\n\n")]

    (str
      "describe('" name " constraints', () => {\n"
      unique-tests injection-test bad-ref-tests bogus-state-test unknown-field-test
      "});\n\n")))

;; --- State machine tests (full BFS coverage) ---

(defn gen-setup-chain [(field :- String) (store-name :- String) (chain :- Any)] :- String
  (.join (mapv (fn [state]
    (str "    await api('PUT', `/api/" store-name "/${created.eid}`, { " field ": '" state "' });\n"))
    chain) ""))

(defn gen-sm-tests [(sm :- Any) (state-machines :- Any) (all-entities :- Any)] :- String
  (let [entity-name (.-entity sm)
        field (.-field sm)
        state-type (.-state-type sm)
        initial (strip-colon (.-initial sm))
        transitions (.-transitions sm)
        entity (first (filterv (fn [e] (= (.-name e) entity-name)) all-entities))
        cap (capitalize entity-name)
        store-name (.-store-name entity)
        all-states (mapv strip-colon (keys transitions))
        chains (bfs-setup-chains transitions (.-initial sm))

        default-test (str
          "  it('defaults to " initial "', async () => {\n"
          "    const e = await create" cap "();\n"
          "    assert.equal(e." field ", '" initial "');\n"
          "  });\n\n")

        state-tests (.join (mapv (fn [state]
          (let [chain (or (get chains state) [])
                state-kw (str ":" state)
                valid-targets (mapv strip-colon (or (get transitions state-kw) []))
                invalid-targets (filterv (fn [s]
                  (and (not= s state) (not (.includes valid-targets s))))
                  all-states)
                setup (gen-setup-chain field store-name chain)

                valid (.join (mapv (fn [target]
                  (str
                    "  it('" state " → " target " succeeds', async () => {\n"
                    "    const created = await create" cap "();\n"
                    setup
                    "    const { status } = await api('PUT', `/api/" store-name "/${created.eid}`, { " field ": '" target "' });\n"
                    "    assert.equal(status, 200);\n"
                    "  });\n\n"))
                  valid-targets) "")

                invalid (.join (mapv (fn [target]
                  (str
                    "  it('" state " → " target " rejects', async () => {\n"
                    "    const created = await create" cap "();\n"
                    setup
                    "    const { status } = await api('PUT', `/api/" store-name "/${created.eid}`, { " field ": '" target "' });\n"
                    "    assert.equal(status, 400);\n"
                    "  });\n\n"))
                  invalid-targets) "")]
            (str valid invalid)))
          all-states) "")]
    (str
      "describe('" state-type " transitions', () => {\n"
      default-test state-tests
      "});\n\n")))

;; --- FK cascade tests ---

(defn gen-cascade-tests [(edge :- Any) (state-machines :- Any) (all-entities :- Any)] :- String
  (let [from-name (.-from-entity edge)
        to-name (.-to-entity edge)
        from-field (.-from-field edge)
        from-entity (first (filterv (fn [e] (= (.-name e) from-name)) all-entities))
        to-entity (first (filterv (fn [e] (= (.-name e) to-name)) all-entities))
        from-store (.-store-name from-entity)
        to-cap (capitalize to-name)
        from-cap (capitalize from-name)]
    (str
      "describe('cascade: " from-name " → " to-name "', () => {\n"
      "  it('deleting " to-name " removes its " from-name "s', async () => {\n"
      "    const parent = await create" to-cap "();\n"
      "    await create" from-cap "({ '" from-field "': Number(parent.eid) });\n"
      "    await api('DELETE', `/api/" (.-store-name to-entity) "/${parent.eid}`);\n"
      "    const { data } = await api('GET', '/api/" from-store "');\n"
      "    const orphaned = data.filter(r => r['" from-field "'] === Number(parent.eid));\n"
      "    assert.equal(orphaned.length, 0);\n"
      "  });\n"
      "});\n\n")))

;; --- Named query tests ---

(defn gen-query-tests [(q :- Any)] :- String
  (let [qname (.-name q)]
    (str
      "describe('query: " qname "', () => {\n"
      "  it('GET /api/queries/" qname " returns array', async () => {\n"
      "    const { status, data } = await api('GET', '/api/queries/" qname "');\n"
      "    assert.equal(status, 200);\n"
      "    assert.ok(Array.isArray(data));\n"
      "  });\n"
      "});\n\n")))

;; --- Health check ---

(defn gen-health-test [] :- String
  #r#"
  describe('health', () => {
    it('GET /health returns ok', async () => {
      const { status, data } = await api('GET', '/health');
      assert.equal(status, 200);
      assert.equal(data.status, 'ok');
      assert.ok(typeof data.uptime === 'number');
    });
  });

  "#
)

;; --- Main ---

(defn gen-tests [(prog :- Any)] :- String
  (let [g (graph/check-program prog)
        entities (.-entities g)
        fk-edges (.-fk-edges g)
        state-machines (.-state-machines g)
        queries (.-queries g)
        src-name (.-ns g)]
    (str
      (gen-preamble src-name)
      (gen-factories entities state-machines)
      (gen-health-test)
      (.join (mapv (fn [e] (gen-crud-tests e state-machines)) entities) "")
      (.join (mapv (fn [e] (gen-constraint-tests e state-machines entities)) entities) "")
      (.join (mapv (fn [sm] (gen-sm-tests sm state-machines entities)) state-machines) "")
      (.join (mapv (fn [edge] (gen-cascade-tests edge state-machines entities)) fk-edges) "")
      (.join (mapv gen-query-tests queries) ""))))
