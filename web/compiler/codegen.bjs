#lang beagle/js
(ns wake.codegen)
(require wake.graph :as graph)
(require wake.ui :as ui)

;; Codegen: Checked Entity Graph → self-contained JavaScript IIFE.
;; Produces direct-DOM code: entity stores, compiled update paths,
;; list-detail view, form handler, undo/redo, persistence.

;; --- Typed records ---

(defrecord RenderResult [(code :- String) (vname :- String) (bindings :- Any)])
(defrecord Binding [(prop :- String) (vname :- String) (dom-prop :- String)])
(defrecord LayoutRef [(id :- String) (vname :- String)])
(defrecord LayoutResult [(code :- String) (refs :- (Vec LayoutRef))])

;; --- JS AST (inline, typed) ---

(defrecord JsIdent [(name :- String)])
(defrecord JsLiteral [(value :- Any)])
(defrecord JsRawExpr [(code :- String)])
(defrecord JsCall [(callee :- JsExpr) (args :- (Vec JsExpr))])
(defrecord JsMember [(obj :- JsExpr) (prop :- String)])
(defrecord JsBinary [(op :- String) (left :- JsExpr) (right :- JsExpr)])
(defrecord JsAwait [(expr :- JsExpr)])
(defrecord JsArrowBlock [(params :- (Vec String)) (body :- (Vec JsStmt))])
(defrecord JsArray [(items :- (Vec JsExpr))])
(defrecord JsSpread [(expr :- JsExpr)])

(defunion JsExpr JsIdent JsLiteral JsRawExpr JsCall JsMember JsBinary JsAwait JsArrowBlock JsArray JsSpread)

(defrecord JsRawStmt [(code :- String)])
(defrecord JsConst [(name :- String) (value :- JsExpr)])
(defrecord JsAssign [(target :- JsExpr) (value :- JsExpr)])
(defrecord JsReturn [(expr :- JsExpr)])
(defrecord JsIf [(test :- JsExpr) (then :- (Vec JsStmt)) (else-branch :- (Vec JsStmt))])
(defrecord JsBlock [(stmts :- (Vec JsStmt))])
(defrecord JsExprStmt [(expr :- JsExpr)])

(defunion JsStmt JsRawStmt JsConst JsAssign JsReturn JsIf JsBlock JsExprStmt)

;; --- JS AST emitter ---

(defn emit-expr [(node :- JsExpr)] :- String
  (match node
    [(JsIdent name) name]
    [(JsLiteral value) (if (string? value) (str "'" value "'") (str value))]
    [(JsRawExpr code) code]
    [(JsCall callee args) (str (emit-expr callee) "(" (.join (mapv emit-expr args) ", ") ")")]
    [(JsMember obj prop) (str (emit-expr obj) "." prop)]
    [(JsBinary op left right) (str (emit-expr left) " " op " " (emit-expr right))]
    [(JsAwait expr) (str "await " (emit-expr expr))]
    [(JsArrowBlock params body) (str "(" (.join params ", ") ") => {\n" (emit-stmts body 1) "\n}")]
    [(JsArray items) (str "[" (.join (mapv emit-expr items) ", ") "]")]
    [(JsSpread expr) (str "..." (emit-expr expr))]))

(defn indent [(depth :- Int)] :- String
  (loop [i 0 acc ""]
    (if (>= i depth) acc (recur (+ i 1) (str acc "  ")))))

(defn emit-stmt [(node :- JsStmt) (depth :- Int)] :- String
  (let [pad (indent depth)]
    (match node
      [(JsRawStmt code) (str pad code)]
      [(JsConst name value) (str pad "const " name " = " (emit-expr value) ";")]
      [(JsAssign target value) (str pad (emit-expr target) " = " (emit-expr value) ";")]
      [(JsReturn expr) (str pad "return " (emit-expr expr) ";")]
      [(JsExprStmt expr) (str pad (emit-expr expr) ";")]
      [(JsIf test then else-branch)
       (let [then-str (str " {\n" (emit-stmts then (+ depth 1)) "\n" pad "}")
             else-str (if (= (count else-branch) 0) ""
                        (str " else {\n" (emit-stmts else-branch (+ depth 1)) "\n" pad "}"))]
         (str pad "if (" (emit-expr test) ")" then-str else-str))]
      [(JsBlock stmts) (emit-stmts stmts depth)])))

(defn emit-stmts [(stmts :- (Vec JsStmt)) (depth :- Int)] :- String
  (.join (mapv (fn [s] (emit-stmt s depth)) stmts) "\n"))

;; --- DOM AST helpers ---

(defn dom-create [(tag :- String)] :- JsExpr
  (->JsCall (->JsMember (->JsIdent "document") "createElement") [(->JsLiteral tag)]))

(defn dom-set-prop [(target :- JsExpr) (prop :- String) (value :- JsExpr)] :- JsStmt
  (->JsAssign (->JsMember target prop) value))

(defn dom-append [(parent :- JsExpr) (child :- JsExpr)] :- JsStmt
  (->JsExprStmt (->JsCall (->JsMember parent "appendChild") [child])))

(defn dom-add-listener [(target :- JsExpr) (event :- String) (handler :- JsExpr)] :- JsStmt
  (->JsExprStmt (->JsCall (->JsMember target "addEventListener") [(->JsLiteral event) handler])))

;; --- Helpers ---

(defn id->ref [(s :- String)] :- String
  (.replaceAll (.replaceAll s "-" "_") "." "_"))

(defn titlecase [(s :- String)] :- String
  (if (= (count s) 0) s
    (.join
      (mapv (fn [w] (if (= (count w) 0) w (str (.toUpperCase (subs w 0 1)) (subs w 1))))
            (.split s " "))
      " ")))

(defn q [(s :- String)] :- String
  (str "\"" s "\""))

(defn sym? [(x :- Any)] :- Bool
  (if (nil? x) false (= (.-_tag x) "Sym")))

(defn sym-name [(x :- Any)] :- String
  (.-name x))


(defn compile-derived-expr [(expr :- Any) (subst :- Any)] :- String
  (if (sym? expr)
    (let [name (sym-name expr)]
      (if (and (not (nil? subst)) (not (nil? (get subst name))))
        (get subst name)
        (str "(entity." name " || '')")))
    (if (and (vector? expr) (> (count expr) 0)
             (sym? (nth expr 0)) (= (sym-name (nth expr 0)) "str"))
      (.join
        (mapv (fn [p]
          (if (string? p) (q p)
            (if (sym? p)
              (let [name (sym-name p)]
                (if (and (not (nil? subst)) (not (nil? (get subst name))))
                  (get subst name)
                  (str "(entity." name " || '')")))
              (compile-derived-expr p subst))))
          (subvec expr 1))
        " + ")
      (if (string? expr) (q expr) "''"))))

;; --- Inlined value-equality runtime (change-gating) ---

;; gen-equiv-runtime — emit equiv/hash/mix as PLAIN (non-exported) function
;; declarations, copied VERBATIM from beagle core.js (lib/beagle/core.js), so
;; each generated app is self-contained (ZERO imports). These back the store
;; change-gate: a write whose value is structurally EQUAL to the current value
;; becomes a true no-op (no mutation, no notify, no superseding claim).
(defn gen-equiv-runtime [] :- String
  (.join
    ["// ── Value equality (Clojure = semantics) ─────────────"
     "function equiv(a, b) {"
     "  // nil: both null and undefined represent Clojure nil."
     "  if (a == null || b == null) return a == null && b == null;"
     "  // identical refs are trivially equal."
     "  if (a === b) return true;"
     "  const ta = typeof a, tb = typeof b;"
     "  // scalars: numbers, strings (keywords emit as bare strings), booleans."
     "  if (ta !== \"object\" || tb !== \"object\") return a === b;"
     "  // both are objects (arrays, plain objects/records, Sets, ...)."
     "  const aArr = Array.isArray(a), bArr = Array.isArray(b);"
     "  if (aArr || bArr) {"
     "    if (!aArr || !bArr) return false;"
     "    if (a.length !== b.length) return false;"
     "    for (let i = 0; i < a.length; i++) if (!equiv(a[i], b[i])) return false;"
     "    return true;"
     "  }"
     "  const aSet = a instanceof Set, bSet = b instanceof Set;"
     "  if (aSet || bSet) {"
     "    if (!aSet || !bSet) return false;"
     "    if (a.size !== b.size) return false;"
     "    const bItems = [...b];"
     "    const used = new Array(bItems.length).fill(false);"
     "    outer: for (const x of a) {"
     "      for (let i = 0; i < bItems.length; i++) {"
     "        if (!used[i] && equiv(x, bItems[i])) { used[i] = true; continue outer; }"
     "      }"
     "      return false;"
     "    }"
     "    return true;"
     "  }"
     "  // plain objects: maps AND records — same own keys, recursive equiv."
     "  const ak = Object.keys(a), bk = Object.keys(b);"
     "  if (ak.length !== bk.length) return false;"
     "  for (const k of ak) {"
     "    if (!Object.prototype.hasOwnProperty.call(b, k)) return false;"
     "    if (!equiv(a[k], b[k])) return false;"
     "  }"
     "  return true;"
     "}"
     "function mix(h, c) {"
     "  return ((h << 5) - h + c) | 0;"
     "}"
     "function hash(x) {"
     "  if (x == null) return 0;"
     "  const t = typeof x;"
     "  if (t === \"number\") {"
     "    return mix(1, x | 0) ^ ((x * 2654435761) | 0);"
     "  }"
     "  if (t === \"string\") {"
     "    let h = 2;"
     "    for (let i = 0; i < x.length; i++) h = mix(h, x.charCodeAt(i));"
     "    return h | 0;"
     "  }"
     "  if (t === \"boolean\") return x ? 3 : 4;"
     "  if (Array.isArray(x)) {"
     "    let h = 5;"
     "    for (let i = 0; i < x.length; i++) h = mix(h, hash(x[i]));"
     "    return h | 0;"
     "  }"
     "  if (x instanceof Set) {"
     "    let acc = 0;"
     "    for (const e of x) acc = (acc + hash(e)) | 0;"
     "    return mix(6, acc);"
     "  }"
     "  if (t === \"object\") {"
     "    let acc = 0;"
     "    for (const k of Object.keys(x)) {"
     "      acc = (acc + mix(hash(k), hash(x[k]))) | 0;"
     "    }"
     "    return mix(7, acc);"
     "  }"
     "  return mix(8, hash(String(x)));"
     "}"
     ""]
    "\n"))

;; --- Entity store ---

(defn gen-store [(name :- String) (fk-methods :- Any)] :- String
  (let [fk-lines (mapv (fn [fk]
                   (str "    by" (titlecase fk) "(fkEid) { return Array.from(entities.values()).filter(e => e." fk " === fkEid); },"))
                   fk-methods)]
    (.join
      (.concat
        [(str "const " name " = (() => {")
         "  let nextEid = 1;"
         "  const entities = new Map();"
         "  const watchers = [];"
         "  function notify(evt) { for (const fn of watchers) fn(evt); }"
         "  return {"
         "    add(fields) {"
         "      const eid = nextEid++;"
         "      const entity = { ...fields, eid };"
         "      entities.set(eid, entity);"
         "      notify({ type: 'add', eid, entity });"
         "      return entity;"
         "    },"
         "    get(eid) { return entities.get(eid); },"
         "    update(eid, attr, value) {"
         "      const entity = entities.get(eid);"
         "      if (!entity) return false;"
         "      const old = entity[attr];"
         "      if (equiv(old, value)) return false;"
         "      entity[attr] = value;"
         "      notify({ type: 'update', eid, entity, attr, old, 'new': value });"
         "      return true;"  ;; change-gated: feed reads this to emit only moved uuids
         "    },"
         "    all() { return Array.from(entities.values()); },"
         "    remove(eid) {"
         "      const entity = entities.get(eid);"
         "      if (!entity) return;"
         "      entities.delete(eid);"
         "      notify({ type: 'remove', eid, entity });"
         "    },"
         "    addBack(entity) {"
         "      entities.set(entity.eid, entity);"
         "      if (entity.eid >= nextEid) nextEid = entity.eid + 1;"
         "      notify({ type: 'add', eid: entity.eid, entity });"
         "    },"]
        fk-lines
        ["    watch(fn) { watchers.push(fn); },"
         "    load(items) {"
         "      entities.clear();"
         "      let maxEid = 0;"
         "      for (const item of items) { entities.set(item.eid, item); if (item.eid > maxEid) maxEid = item.eid; }"
         "      nextEid = maxEid + 1;"
         "      notify({ type: 'load' });"
         "    },"
         "    snapshot() { return Array.from(entities.values()); }"
         "  };"
         "})();"])
      "\n")))

;; gen-store-claims — a CLAIM-BACKED store with gen-store's exact interface (ADR 0001).
;; Internally an append-only claim log (subject predicate object) with supersession:
;; update keeps the old value (marked sup) so HISTORY is intrinsic; remove tombstones
;; (non-destructive); snapshot() is the LOG so localStorage persists history, not just
;; current state. The rest of the app is unchanged. JS sibling: web/runtime/claim-store.js.
(defn gen-store-claims [(name :- String) (fk-methods :- Any)] :- String
  (let [fk-lines (mapv (fn [fk]
                   (str "    by" (titlecase fk) "(fkEid) { return entityIds().filter(e => !tombstoned(e)).map(project).filter(e => e." fk " === fkEid); },"))
                   fk-methods)]
    (.join
      (.concat
        [(str "const " name " = (() => {")
         "  let nextEid = 1, nextCid = 1;"
         "  const claims = [];"
         "  const watchers = [];"
         "  function notify(evt) { for (const fn of watchers) fn(evt); }"
         "  function liveClaim(eid, attr) { let f = null; for (const c of claims) if (c.l === eid && c.p === attr && !c.sup) f = c; return f; }"
         "  function tombstoned(eid) { return !!liveClaim(eid, '__tombstoned'); }"
         "  function project(eid) { const e = { eid }; for (const c of claims) if (c.l === eid && !c.sup && !c.p.startsWith('__')) e[c.p] = c.r; return e; }"
         "  function entityIds() { const seen = new Set(), out = []; for (const c of claims) if (!seen.has(c.l)) { seen.add(c.l); out.push(c.l); } return out; }"
         "  return {"
         "    add(fields) { const eid = nextEid++; for (const k in fields) claims.push({ cid: nextCid++, l: eid, p: k, r: fields[k], sup: false }); const entity = project(eid); notify({ type: 'add', eid, entity }); return entity; },"
         "    get(eid) { return (tombstoned(eid) || !entityIds().includes(eid)) ? undefined : project(eid); },"
         "    update(eid, attr, value) { const old = liveClaim(eid, attr); if (old && equiv(old.r, value)) return false; if (old) old.sup = true; claims.push({ cid: nextCid++, l: eid, p: attr, r: value, sup: false }); notify({ type: 'update', eid, entity: project(eid), attr, old: old ? old.r : undefined, 'new': value }); return true; },"
         "    all() { return entityIds().filter(e => !tombstoned(e)).map(project); },"
         "    remove(eid) { claims.push({ cid: nextCid++, l: eid, p: '__tombstoned', r: true, sup: false }); notify({ type: 'remove', eid }); },"
         "    addBack(entity) { const t = liveClaim(entity.eid, '__tombstoned'); if (t) t.sup = true; if (!entityIds().includes(entity.eid)) { for (const k in entity) if (k !== 'eid') claims.push({ cid: nextCid++, l: entity.eid, p: k, r: entity[k], sup: false }); if (entity.eid >= nextEid) nextEid = entity.eid + 1; } notify({ type: 'add', eid: entity.eid, entity: project(entity.eid) }); },"]
        fk-lines
        ["    watch(fn) { watchers.push(fn); },"
         "    load(snap) { claims.length = 0; if (snap && Array.isArray(snap.claims)) { for (const c of snap.claims) claims.push({ ...c }); nextEid = snap.nextEid || 1; nextCid = snap.nextCid || 1; } else if (Array.isArray(snap)) { for (const it of snap) { for (const k in it) if (k !== 'eid') claims.push({ cid: nextCid++, l: it.eid, p: k, r: it[k], sup: false }); if (it.eid >= nextEid) nextEid = it.eid + 1; } } notify({ type: 'load' }); },"
         "    snapshot() { return { claims: claims.map(c => ({ ...c })), nextEid, nextCid }; },"
         "    history(eid, attr) { return claims.filter(c => c.l === eid && c.p === attr).map(c => ({ value: c.r, live: !c.sup })); }"
         "  };"
         "})();"])
      "\n")))

;; --- Detail panel ---

(defn gen-detail [(en :- String) (store-name :- String) (overview-fields :- Any)
                  (derived-attrs :- Any) (related-info :- Any) (field-info :- Any)] :- String
  (let [tab-active-cls "px-4 py-2 text-sm font-medium border-b-2 border-primary text-foreground"
        tab-inactive-cls "px-4 py-2 text-sm font-medium text-muted-foreground"
        delete-svg "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M3 6h18\"></path><path d=\"M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6\"></path><path d=\"M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2\"></path></svg>"
        close-svg "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"></line><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"></line></svg>"
        container-ref (id->ref (str "ld-" en "-detail"))

        ;; Delete cascade lines
        delete-lines (.join
          (mapv (fn [ri]
            (str "    for (const r of " (.-store ri) ".by" (titlecase (.-fk-field ri)) "(selectedContact)) " (.-store ri) ".remove(r.eid);"))
            related-info)
          "\n")

        ;; Tab bar construction
        tab-bar-lines (str
          "  detailNodes.tabOverview = document.createElement('button');\n"
          "  detailNodes.tabOverview.textContent = 'Overview';\n"
          "  detailNodes.tabOverview.className = '" tab-active-cls "';\n"
          "  detailNodes.tabOverview.addEventListener('click', () => { activeTab = 'overview'; renderDetail(); });\n"
          "  tabBar.appendChild(detailNodes.tabOverview);\n"
          (.join
            (mapv (fn [ri]
              (let [key (.-key ri)]
                (str "  detailNodes.tab_" key " = document.createElement('button');\n"
                     "  detailNodes.tab_" key ".textContent = " (q (titlecase key)) ";\n"
                     "  detailNodes.tab_" key ".className = '" tab-inactive-cls "';\n"
                     "  detailNodes.tab_" key ".addEventListener('click', () => { activeTab = " (q key) "; renderDetail(); });\n"
                     "  tabBar.appendChild(detailNodes.tab_" key ");")))
              related-info)
            "\n"))

        ;; Overview field grid
        field-grid-lines (.join
          (mapv (fn [f]
            (str "  const " f "Label = document.createElement('span');\n"
                 "  " f "Label.className = 'text-xs font-medium uppercase text-muted-foreground';\n"
                 "  " f "Label.textContent = " (q (titlecase f)) ";\n"
                 "  grid.appendChild(" f "Label);\n"
                 "  detailNodes.field_" f " = document.createElement('span');\n"
                 "  detailNodes.field_" f ".className = 'text-sm';\n"
                 "  grid.appendChild(detailNodes.field_" f ");\n"
                 "  makeEditable(detailNodes.field_" f ", " (q f) ");"))
            overview-fields)
          "\n")

        ;; Derived field grid entries (non-editable)
        derived-grid-lines (.join
          (mapv (fn [da]
            (let [dname (id->ref (.-name da))
                  label (titlecase (.replaceAll (.-name da) "-" " "))]
              (str "  const " dname "Label = document.createElement('span');\n"
                   "  " dname "Label.className = 'text-xs font-medium uppercase text-muted-foreground';\n"
                   "  " dname "Label.textContent = " (q label) ";\n"
                   "  grid.appendChild(" dname "Label);\n"
                   "  detailNodes.field_" dname " = document.createElement('span');\n"
                   "  detailNodes.field_" dname ".className = 'text-sm italic text-muted-foreground';\n"
                   "  grid.appendChild(detailNodes.field_" dname ");")))
            derived-attrs)
          "\n")

        ;; Related tab content areas (typed AST)
        related-content-lines (.join
          (mapv (fn [ri]
            (let [key (.-key ri)
                  rel-en (.-entity ri)
                  rel-store (.-store ri)
                  fk-field (.-fk-field ri)
                  dn (->JsIdent "detailNodes")
                  content (->JsMember dn (str key "Content"))
                  header (->JsMember dn (str key "Header"))
                  lst (->JsMember dn (str key "List"))
                  input (->JsMember dn (str key "Input"))
                  form-row (->JsIdent (str key "FormRow"))
                  add-btn (->JsIdent (str key "AddBtn"))
                  wrapper (->JsMember dn "wrapper")]
              (emit-stmts
                [(dom-set-prop dn (str key "Content") (dom-create "div"))
                 (dom-set-prop content "className" (->JsLiteral "p-4 flex-1 overflow-y-auto flex flex-col"))
                 (dom-set-prop content "style.display" (->JsLiteral "none"))
                 (dom-set-prop dn (str key "Header") (dom-create "h3"))
                 (dom-set-prop header "className" (->JsLiteral "text-sm font-medium mb-2"))
                 (dom-append content header)
                 (dom-set-prop dn (str key "List") (dom-create "div"))
                 (dom-set-prop lst "className" (->JsLiteral "flex-1 space-y-2 mb-3"))
                 (dom-append content lst)
                 (->JsConst (str key "FormRow") (dom-create "div"))
                 (dom-set-prop form-row "className" (->JsLiteral "flex gap-2"))
                 (dom-set-prop dn (str key "Input") (dom-create "textarea"))
                 (dom-set-prop input "className" (->JsLiteral "flex-1 px-3 py-2 border border-input rounded-md bg-background text-foreground text-sm resize-none"))
                 (dom-set-prop input "placeholder" (->JsLiteral (str "Add a " rel-en "...")))
                 (dom-set-prop input "rows" (->JsRawExpr "2"))
                 (dom-append form-row input)
                 (->JsConst (str key "AddBtn") (dom-create "button"))
                 (dom-set-prop add-btn "className" (->JsLiteral "px-3 py-2 bg-primary text-primary-foreground rounded-md text-sm font-medium hover:opacity-90 self-end"))
                 (dom-set-prop add-btn "textContent" (->JsLiteral "Add"))
                 (dom-add-listener add-btn "click"
                   (->JsArrowBlock []
                     [(->JsConst "content" (->JsRawExpr (str "detailNodes." key "Input.value.trim()")))
                      (->JsRawStmt (str "if (!content || !selectedContact) return;"))
                      (->JsExprStmt (->JsCall (->JsMember (->JsIdent rel-store) "add")
                        [(->JsRawExpr (str "{ content, " fk-field ": selectedContact, 'created-at': new Date().toISOString() }"))]))
                      (dom-set-prop input "value" (->JsLiteral ""))]))
                 (dom-append form-row add-btn)
                 (dom-append content form-row)
                 (dom-append wrapper content)]
                1)))
            related-info)
          "\n")

        ;; Related tab render functions
        render-related-fns (.join
          (mapv (fn [ri]
            (let [key (.-key ri)
                  rel-store (.-store ri)
                  fk-field (.-fk-field ri)
                  display (or (.-display ri) [])
                  render-fn (str "render" (titlecase key))]
              (str "function " render-fn "() {\n"
                   "  detailNodes." key "List.innerHTML = '';\n"
                   "  if (!selectedContact) return;\n"
                   "  detailNodes." key "Header.textContent = '" (titlecase key) " for ' + (" store-name ".get(selectedContact)?.name || '');\n"
                   "  const items = " rel-store ".by" (titlecase fk-field) "(selectedContact)\n"
                   "    .sort((a, b) => (b['created-at'] || '').localeCompare(a['created-at'] || ''));\n"
                   "  if (items.length === 0) {\n"
                   "    const empty = document.createElement('div');\n"
                   "    empty.className = 'text-sm text-muted-foreground';\n"
                   "    empty.textContent = 'No " key " yet';\n"
                   "    detailNodes." key "List.appendChild(empty);\n"
                   "    return;\n"
                   "  }\n"
                   "  for (const item of items) {\n"
                   "    const el = document.createElement('div');\n"
                   "    el.className = 'p-2 border border-border rounded-md flex justify-between items-start gap-2';\n"
                   "    const elBody = document.createElement('div');\n"
                   "    elBody.className = 'flex-1 min-w-0';\n"
                   (.join
                     (mapv (fn [col]
                       (let [cref (id->ref col)
                             tag (if (= col "content") "p" "span")
                             cls (if (= col "content") "text-sm" "text-xs text-muted-foreground mt-1 block")]
                         (str "    const " cref "El = document.createElement('" tag "');\n"
                              "    " cref "El.className = '" cls "';\n"
                              "    " cref "El.textContent = item['" col "'] || '';\n"
                              "    elBody.appendChild(" cref "El);")))
                       display)
                     "\n")
                   "\n    el.appendChild(elBody);\n"
                   "    const delBtn = document.createElement('button');\n"
                   "    delBtn.className = 'text-muted-foreground hover:text-red-600 text-sm px-1 flex-shrink-0';\n"
                   "    delBtn.textContent = '\\u00d7';\n"
                   "    delBtn.addEventListener('click', () => " rel-store ".remove(item.eid));\n"
                   "    el.appendChild(delBtn);\n"
                   "    detailNodes." key "List.appendChild(el);\n"
                   "  }\n"
                   "}\n")))
            related-info)
          "\n")

        ;; renderDetail function
        clear-fields (.join
          (mapv (fn [f] (str "    detailNodes.field_" f ".textContent = '';"))
                overview-fields)
          "\n")
        clear-derived (.join
          (mapv (fn [da]
            (str "    detailNodes.field_" (id->ref (.-name da)) ".textContent = '';"))
            derived-attrs)
          "\n")
        set-fields (.join
          (mapv (fn [f] (str "  detailNodes.field_" f ".textContent = entity." f " || '';"))
                overview-fields)
          "\n")
        set-derived (.join
          (mapv (fn [da]
            (str "  detailNodes.field_" (id->ref (.-name da)) ".textContent = " (compile-derived-expr (.-expr da) nil) ";"))
            derived-attrs)
          "\n")
        subtitle-field (if (> (count overview-fields) 1) (nth overview-fields 1) nil)
        tab-active-update (str
          "  detailNodes.tabOverview.className = activeTab === 'overview'\n"
          "    ? '" tab-active-cls "'\n"
          "    : '" tab-inactive-cls "';\n"
          (.join
            (mapv (fn [ri]
              (let [key (.-key ri)]
                (str "  detailNodes.tab_" key ".className = activeTab === " (q key) "\n"
                     "    ? '" tab-active-cls "'\n"
                     "    : '" tab-inactive-cls "';")))
              related-info)
            "\n"))
        tab-visibility (str
          "  detailNodes.overviewContent.style.display = activeTab !== 'overview' ? 'none' : '';\n"
          (.join
            (mapv (fn [ri]
              (str "  detailNodes." (.-key ri) "Content.style.display = activeTab !== " (q (.-key ri)) " ? 'none' : '';"))
              related-info)
            "\n"))
        tab-render (.join
          (mapv (fn [ri]
            (let [key (.-key ri)]
              (str "  if (activeTab === " (q key) ") render" (titlecase key) "();")))
            related-info)
          "\n")]

    (str
      "let selectedContact = null;\n"
      "let activeTab = 'overview';\n\n"
      "function selectContact(eid) {\n"
      "  selectedContact = eid;\n"
      "  renderDetail();\n"
      "}\n\n"
      "const detailNodes = {};\n\n"

      ;; makeEditable — type-aware inline editing
      ;; fieldTypes maps attr names to { kind, options }
      "const fieldTypes = " (gen-field-types-map field-info) ";\n\n"
      "function makeEditable(el, attr) {\n"
      "  el.style.cursor = 'pointer';\n"
      "  el.addEventListener('click', () => {\n"
      "    if (!selectedContact) return;\n"
      "    let done = false;\n"
      "    const ft = fieldTypes[attr];\n"
      "    const kind = ft ? ft.kind : 'text';\n"
      "    let input;\n"
      "    if (kind === 'select') {\n"
      "      input = document.createElement('select');\n"
      "      for (const opt of ft.options) {\n"
      "        const o = document.createElement('option');\n"
      "        o.value = opt; o.textContent = opt;\n"
      "        if (opt === el.textContent) o.selected = true;\n"
      "        input.appendChild(o);\n"
      "      }\n"
      "    } else if (kind === 'checkbox') {\n"
      "      input = document.createElement('input');\n"
      "      input.type = 'checkbox';\n"
      "      input.checked = el.textContent === 'true';\n"
      "    } else {\n"
      "      input = document.createElement('input');\n"
      "      input.type = kind;\n"
      "      input.value = el.textContent;\n"
      "    }\n"
      "    input.className = 'text-sm w-full px-1 py-0 border border-input rounded bg-background text-foreground outline-none';\n"
      "    el.replaceWith(input);\n"
      "    input.focus();\n"
      "    function commit() {\n"
      "      if (done) return;\n"
      "      done = true;\n"
      "      const val = kind === 'checkbox' ? String(input.checked) : input.value.trim();\n"
      "      input.replaceWith(el);\n"
      "      " store-name ".update(selectedContact, attr, val);\n"
      "    }\n"
      "    if (kind === 'select') {\n"
      "      input.addEventListener('change', commit);\n"
      "      input.addEventListener('blur', commit);\n"
      "    } else {\n"
      "      input.addEventListener('blur', commit);\n"
      "      input.addEventListener('keydown', (e) => {\n"
      "        if (e.key === 'Enter') { e.preventDefault(); commit(); }\n"
      "        if (e.key === 'Escape') { done = true; input.replaceWith(el); }\n"
      "      });\n"
      "    }\n"
      "  });\n"
      "}\n\n"

      ;; buildDetailPanel
      "function buildDetailPanel() {\n"
      "  const container = " container-ref ";\n\n"
      "  detailNodes.emptyState = document.createElement('div');\n"
      "  detailNodes.emptyState.className = 'flex items-center justify-center h-full text-muted-foreground text-sm';\n"
      "  detailNodes.emptyState.textContent = 'Select a " en " to view details';\n\n"
      "  detailNodes.wrapper = document.createElement('div');\n"
      "  detailNodes.wrapper.className = 'flex flex-col h-full';\n"
      "  detailNodes.wrapper.style.display = 'none';\n\n"
      ;; Header
      "  const header = document.createElement('div');\n"
      "  header.className = 'flex items-center justify-between p-4 border-b border-border';\n"
      "  const headerLeft = document.createElement('div');\n"
      "  detailNodes.title = document.createElement('h2');\n"
      "  detailNodes.title.className = 'text-lg font-semibold';\n"
      "  detailNodes.subtitle = document.createElement('p');\n"
      "  detailNodes.subtitle.className = 'text-sm text-muted-foreground';\n"
      "  headerLeft.appendChild(detailNodes.title);\n"
      "  headerLeft.appendChild(detailNodes.subtitle);\n"
      "  const headerRight = document.createElement('div');\n"
      "  headerRight.className = 'flex items-center gap-1';\n"
      "  const deleteBtn = document.createElement('button');\n"
      "  deleteBtn.className = 'p-1 rounded hover:bg-red-100 text-muted-foreground hover:text-red-600 transition-colors';\n"
      "  deleteBtn.innerHTML = '" delete-svg "';\n"
      "  deleteBtn.addEventListener('click', () => {\n"
      "    if (!selectedContact) return;\n"
      "    beginTransaction();\n"
      delete-lines "\n"
      "    " store-name ".remove(selectedContact);\n"
      "    commitTransaction();\n"
      "  });\n"
      "  const closeBtn = document.createElement('button');\n"
      "  closeBtn.className = 'p-1 rounded hover:bg-muted';\n"
      "  closeBtn.innerHTML = '" close-svg "';\n"
      "  closeBtn.addEventListener('click', () => selectContact(null));\n"
      "  headerRight.appendChild(deleteBtn);\n"
      "  headerRight.appendChild(closeBtn);\n"
      "  header.appendChild(headerLeft);\n"
      "  header.appendChild(headerRight);\n"
      "  detailNodes.wrapper.appendChild(header);\n\n"
      ;; Tab bar
      "  const tabBar = document.createElement('div');\n"
      "  tabBar.className = 'flex border-b border-border';\n"
      tab-bar-lines "\n"
      "  detailNodes.wrapper.appendChild(tabBar);\n\n"
      ;; Overview content
      "  detailNodes.overviewContent = document.createElement('div');\n"
      "  detailNodes.overviewContent.className = 'p-4 flex-1 overflow-y-auto';\n"
      "  const grid = document.createElement('div');\n"
      "  grid.className = 'grid grid-cols-2 gap-3';\n"
      field-grid-lines "\n"
      derived-grid-lines "\n"
      "  detailNodes.overviewContent.appendChild(grid);\n"
      "  detailNodes.wrapper.appendChild(detailNodes.overviewContent);\n\n"
      ;; Related tab content
      related-content-lines "\n"
      "\n  container.appendChild(detailNodes.emptyState);\n"
      "  container.appendChild(detailNodes.wrapper);\n"
      "}\n\n"
      ;; Related render functions
      render-related-fns "\n"
      ;; renderDetail
      "function renderDetail() {\n"
      "  if (!selectedContact) {\n"
      "    detailNodes.emptyState.style.display = '';\n"
      "    detailNodes.wrapper.style.display = 'none';\n"
      "    detailNodes.title.textContent = '';\n"
      "    detailNodes.subtitle.textContent = '';\n"
      clear-fields "\n"
      clear-derived "\n"
      "    return;\n"
      "  }\n"
      "  const entity = " store-name ".get(selectedContact);\n"
      "  if (!entity) {\n"
      "    detailNodes.emptyState.style.display = '';\n"
      "    detailNodes.wrapper.style.display = 'none';\n"
      "    return;\n"
      "  }\n"
      "  detailNodes.emptyState.style.display = 'none';\n"
      "  detailNodes.wrapper.style.display = '';\n\n"
      "  detailNodes.title.textContent = entity.name || '';\n"
      (if (not (nil? subtitle-field))
        (str "  detailNodes.subtitle.textContent = entity." subtitle-field " || '';\n")
        "")
      "\n"
      set-fields "\n"
      set-derived "\n"
      "\n"
      tab-active-update "\n"
      "\n"
      tab-visibility "\n"
      tab-render "\n"
      "}\n")))

;; --- List view ---

(defn gen-list-fns [(en :- String) (store-name :- String) (columns :- Any)
                    (search-cols :- Any) (derived-attrs :- Any)] :- String
  (let [list-ref (id->ref (str "ld-" en "-list"))
        search-ref (id->ref (str "ld-" en "-search"))
        ;; All cell names: regular columns + derived field refs
        all-cells (into (vec columns) (mapv (fn [da] (id->ref (.-name da))) derived-attrs))
        ;; Column cells in addRow
        col-cells (.join
          (mapv (fn [col]
            (str "  const " col "Cell = document.createElement('span');\n"
                 "  " col "Cell.className = 'text-sm truncate flex-1';\n"
                 "  " col "Cell.textContent = entity." col " || '';\n"
                 "  inner.appendChild(" col "Cell);"))
            columns)
          "\n")
        ;; Derived cells in addRow
        derived-cells (.join
          (mapv (fn [da]
            (let [dname (id->ref (.-name da))
                  expr (.-expr da)]
              (str "  const " dname "Cell = document.createElement('span');\n"
                   "  " dname "Cell.className = 'text-sm truncate flex-1 text-muted-foreground italic';\n"
                   "  " dname "Cell.textContent = " (compile-derived-expr expr nil) ";\n"
                   "  inner.appendChild(" dname "Cell);")))
            derived-attrs)
          "\n")
        ;; Search text expression
        search-text-expr (str "[" (.join (mapv (fn [c] (str "entity." c " || ''")) search-cols) ", ") "].join(' ').toLowerCase()")
        ;; Cells object entries
        cells-entries (.join (mapv (fn [c] (str c ": " c "Cell")) all-cells) ", ")]

    (str
      "const rowEls = new Map();\n\n"

      "function addRow(entity) {\n"
      "  const row = document.createElement('div');\n"
      "  row.className = 'ld-row flex items-center px-4 py-2.5 border-b border-border cursor-pointer transition-colors hover:bg-muted/50';\n"
      "  const inner = document.createElement('div');\n"
      "  inner.className = 'flex-1 flex gap-4';\n"
      col-cells "\n"
      derived-cells "\n"
      "  row.appendChild(inner);\n"
      "  row.addEventListener('click', () => selectContact(entity.eid));\n"
      "  " list-ref ".appendChild(row);\n"
      "  rowEls.set(entity.eid, {\n"
      "    el: row,\n"
      "    searchText: " search-text-expr ",\n"
      "    cells: { " cells-entries " }\n"
      "  });\n"
      "}\n\n"

      "function removeRow(eid) {\n"
      "  const entry = rowEls.get(eid);\n"
      "  if (entry) { entry.el.remove(); rowEls.delete(eid); }\n"
      "}\n\n"

      "function rebuildList() {\n"
      "  " list-ref ".innerHTML = '';\n"
      "  rowEls.clear();\n"
      "  const sorted = " store-name ".all().slice().sort((a, b) => (a.name || '').localeCompare(b.name || ''));\n"
      "  for (const entity of sorted) addRow(entity);\n"
      "  filterRows();\n"
      "}\n\n"

      "function filterRows() {\n"
      "  const term = " search-ref ".value.toLowerCase();\n"
      "  for (const [, entry] of rowEls) {\n"
      "    entry.el.hidden = (term !== '' && !entry.searchText.includes(term));\n"
      "  }\n"
      "}\n")))

;; --- Stats ---

(defn gen-stats [(en :- String) (store-name :- String)] :- String
  (let [stats-ref (id->ref (str "ld-" en "-stats"))
        count-var (str (id->ref en) "Count")]
    (str "let " count-var " = 0;\n"
         "function updateStats() {\n"
         "  " count-var " = " store-name ".all().length;\n"
         "  " stats-ref ".textContent = 'Total: ' + " count-var ";\n"
         "}\n")))

;; --- Form handler ---

(defn gen-form-handler [(en :- String) (form :- Any)] :- String
  (let [form-name (.-name form)
        fields (.-fields form)
        field-info (.-field-info form)
        status-default (.-status-default form)
        ;; Val declarations — type-aware
        val-decls (.join
          (mapv (fn [f]
            (let [ref (id->ref (str "form-" form-name "-" f))
                  fi (field-info-for field-info f)
                  kind (if (nil? fi) "text" (.-kind fi))]
              (cond
                (= kind "checkbox")
                  (str "  const " ref "_val = " ref ".checked;")
                :else
                  (str "  const " ref "_val = " ref ".value.trim();"))))
            fields)
          "\n")
        ;; First field validation
        first-ref (id->ref (str "form-" form-name "-" (nth fields 0)))
        ;; Add fields
        add-fields (.join
          (mapv (fn [f]
            (let [ref (id->ref (str "form-" form-name "-" f))]
              (if (and (= f "status") (not (nil? status-default)))
                (str f ": " ref "_val || " (q status-default))
                (str f ": " ref "_val"))))
            fields)
          ", ")
        ;; Clear fields — type-aware
        clear-lines (.join
          (mapv (fn [f]
            (let [ref (id->ref (str "form-" form-name "-" f))
                  fi (field-info-for field-info f)
                  kind (if (nil? fi) "text" (.-kind fi))]
              (cond
                (= kind "checkbox")
                  (str "  " ref ".checked = false;")
                (= kind "select")
                  (str "  " ref ".selectedIndex = 0;")
                :else
                  (str "  " ref ".value = '';"))))
            fields)
          "\n")
        status-in-form (some (fn [f] (= f "status")) fields)]
    (str "function handleSubmit(e) {\n"
         "  e.preventDefault();\n"
         val-decls "\n"
         "  if (!" first-ref "_val) return;\n"
         "  " (str en "s") ".add({ " add-fields
         (if (and (not (nil? status-default)) (not status-in-form))
           (str ", status: " (q status-default)) "")
         " });\n"
         clear-lines "\n"
         "}\n")))

;; --- Persistence ---

(defn gen-persistence [(persist-key :- Any) (all-stores :- Any)] :- String
  (let [snapshot-entries (.join
          (mapv (fn [s] (str "      " s ": " s ".snapshot()")) all-stores)
          ",\n")
        restore-lines (.join
          (mapv (fn [s] (str "      if (data." s ") " s ".load(data." s ");")) all-stores)
          "\n")]
    (str "function saveDb() {\n"
         "  try {\n"
         "    localStorage.setItem(" (q persist-key) ", JSON.stringify({\n"
         snapshot-entries "\n"
         "    }));\n"
         "  } catch(_) {}\n"
         "}\n"
         "function restoreDb() {\n"
         "  try {\n"
         "    const raw = localStorage.getItem(" (q persist-key) ");\n"
         "    if (!raw) return;\n"
         "    const data = JSON.parse(raw);\n"
         "    if (Array.isArray(data)) {\n"
         "      " (nth all-stores 0) ".load(data);\n"
         "    } else {\n"
         restore-lines "\n"
         "    }\n"
         "  } catch(_) {}\n"
         "}\n")))

;; --- Live external feed (read-only mirror, real-time per-row push) ---
;; Binds a store to an external HTTP endpoint returning a JSON array, kept live by the daemon
;; /live commit-feed WebSocket. Rows are DIFFED into the store by the entity's identity field:
;; each row that changed fires store.update(eid, attr, v) per field (change-gated — equal values
;; are no-ops), new rows store.add(), vanished rows store.remove(). No whole-store load(), so the
;; DOM is touched only where data actually moved and transient view state (selection) survives.
;;
;; The /live WS pushes raw {op,l,p,r} commits; we treat each as a "something changed" signal and
;; coalesce a re-pull of the aggregated rows (the bridge owns claims->rows aggregation). A slow
;; backstop poll covers a dropped commit. Identity index is feed-runtime-local: it does NOT
;; re-key the store internals (that's the held stable-identity-keying work).
(def feed-runtime-src #r#"const _feedIndex = new Map(); // identity value -> stable eid
let _feedTimer = null;
let _feedWS = null;
let _feedPending = null;

// Diff incoming rows into the store by identity field; per-row update/add/remove (change-gated).
// Returns the identity values (uuids) that actually moved — handed to feed.onUpdate subscribers.
function applyFeedRows(rows) {
  const arr = Array.isArray(rows) ? rows : [];
  if (!_feedIdField) {
    // No identity field declared: fall back to whole-store replace.
    _feedStore.load(arr.map((row, i) => ({ ...row, eid: i + 1 })));
    return;
  }
  const seen = new Set();
  const changed = [];
  for (const row of arr) {
    const key = String(row[_feedIdField]);
    seen.add(key);
    let eid = _feedIndex.get(key);
    if (eid == null) {
      const ent = _feedStore.add({ ...row });
      _feedIndex.set(key, ent.eid);
      changed.push(key);                                   // new agent
    } else {
      let moved = false;
      for (const k in row) { if (k !== 'eid' && _feedStore.update(eid, k, row[k])) moved = true; }
      if (moved) changed.push(key);                        // some field actually moved (not gated away)
    }
  }
  for (const [key, eid] of Array.from(_feedIndex.entries())) {
    if (!seen.has(key)) { _feedStore.remove(eid); _feedIndex.delete(key); changed.push(key); }  // vanished
  }
  if (changed.length) _emitFeedUpdate(changed);
}

async function loadFromFeed() {
  try {
    const r = await fetch(_feedUrl);
    if (!r.ok) return;
    applyFeedRows(await r.json());
  } catch (err) { console.error('feed load failed:', err); }
}

// Derive the /live WS url from the feed http url: same host, ws(s) scheme, sibling /live path.
function feedWsUrl() {
  try {
    const u = new URL(_feedUrl, location.href);
    u.protocol = (u.protocol === 'https:') ? 'wss:' : 'ws:';
    const p = u.pathname;
    const slash = p.lastIndexOf('/');
    u.pathname = (slash >= 0 ? p.slice(0, slash) : '') + '/live';
    return u.toString();
  } catch (_) { return null; }
}

function openFeedWS() {
  const wsUrl = feedWsUrl();
  if (!wsUrl) return;
  try {
    const ws = new WebSocket(wsUrl);
    _feedWS = ws;
    ws.onmessage = () => {
      if (_feedPending) return; // coalesce a burst of commits into one refetch
      _feedPending = setTimeout(() => { _feedPending = null; loadFromFeed(); }, 150);
    };
    ws.onclose = () => { _feedWS = null; setTimeout(openFeedWS, 2000); };
    ws.onerror = () => { try { ws.close(); } catch (_) {} };
  } catch (_) { setTimeout(openFeedWS, 2000); }
}

function startFeed() {
  loadFromFeed();                                  // initial snapshot
  openFeedWS();                                    // real-time push
  _feedTimer = setInterval(loadFromFeed, 15000);   // slow backstop for any dropped commit
}

// --- window.wake: the cross-surface bus (SEAM with the shell). The shell owns the outer
// layout and reads our stores/selection/feed by contract. Selection speaks IDENTITY (uuid);
// we map uuid->eid at our boundary so neither side leaks its internal id. ---
const _feedSubs = new Set();
let _selectedUuid = null;

function _emitFeedUpdate(changed) {
  const payload = { name: _feedStoreName, changed };     // { name, changed:[uuid,...] } — the delta we already diffed
  for (const cb of _feedSubs) { try { cb(payload); } catch (err) { console.error('wake feed subscriber threw:', err); } }
}

(function installWakeBus() {
  const wake = (window.wake = window.wake || {});
  wake.stores = wake.stores || {};
  wake.stores[_feedStoreName] = _feedStore;
  wake.selection = wake.selection || {
    // uuid -> eid at our boundary. No-op (false) if the agent isn't indexed yet; never throws.
    set(uuid) {
      if (uuid == null) { _selectedUuid = null; return false; }
      const key = String(uuid);
      if (!_feedIndex.has(key)) return false;
      _selectedUuid = key;
      return true;
    },
    get() { return _selectedUuid; },                       // null cleanly when nothing is selected
  };
  wake.feed = wake.feed || {};
  wake.feed.name = _feedStoreName;
  wake.feed.onUpdate = (cb) => { if (typeof cb === 'function') _feedSubs.add(cb); return () => _feedSubs.delete(cb); };
  // Ready signal: resolve a promise AND fire an event — a subscriber loading before OR after
  // us both win, with no guarding for undefined.
  window.wakeReady = Promise.resolve(wake);
  try { window.dispatchEvent(new CustomEvent('wake:ready', { detail: wake })); } catch (_) {}
})();

// Bridge the view's internal eid → bus identity. The view calls this on every selectItem;
// we resolve the entity's identity field and push it to the shared selection (custom panes
// read wake.selection.get()). eid===null clears. No id field ⇒ no-op (bus stays uuid-clean).
function _wakePushSelection(eid) {
  if (!window.wake || !window.wake.selection) return;
  if (eid == null) { window.wake.selection.set(null); return; }
  const ent = _feedStore.get ? _feedStore.get(eid) : null;
  const idv = (ent && _feedIdField) ? ent[_feedIdField] : null;
  window.wake.selection.set(idv == null ? null : idv);
}
"#)

(defn gen-feed-persistence [(url :- Any) (store-name :- String) (id-field :- Any)] :- String
  (str "const _feedUrl = " (q url) ";\n"
       "const _feedStore = " store-name ";\n"
       "const _feedStoreName = " (q store-name) ";\n"
       "const _feedIdField = " (if (nil? id-field) "null" (q id-field)) ";\n"
       feed-runtime-src))

;; --- Theme: (theme :colors (background "oklch(...)" ...)) sets CSS custom properties on
;; :root so the utility classes (text-foreground, bg-background, …) resolve. Emitted as an
;; injected <style> in init so a no-build deploy (wake app dropped into a static host) is
;; self-contained — the var values ride in the JS, the utility→var mapping rides in dist.css.
;; (Was parsed-and-threaded but never emitted — a silent no-op; this closes that.) ---
(defn gen-theme-style [(theme :- Any)] :- String
  (if (nil? theme) ""
    (let [colors (.-colors theme)
          decls (.join
                  (mapv (fn [k] (str "    --" k ": " (get colors k) ";\\n")) (keys colors))
                  "")]
      (str "  { const _themeStyle = document.createElement('style');\n"
           "    _themeStyle.textContent = ':root {\\n" decls "}';\n"
           "    document.head.appendChild(_themeStyle); }\n"))))

;; --- Escape-hatch panels: mount shell-owned custom panes (Cytoscape/stream) into named
;; containers carved from the wake view. The pane fn receives { el, wake } so it shares the
;; same feed (feed.onUpdate) + selection as the entity-view. mount-fn is a dotted path
;; resolved off window at runtime; a missing fn warns and no-ops (never throws). ---
(defn gen-panels-mount [(panels :- Any) (parent-var :- String)] :- String
  (if (empty? panels) ""
    (str
      "\n  // ── Escape-hatch panels (shell-owned custom panes; share window.wake) ──────\n"
      "  const _wakeResolve = (path) => path.split('.').reduce((o, k) => (o == null ? null : o[k]), window);\n"
      (.join
        (mapv (fn [p]
          (let [ref (id->ref (.-name p))
                dom-id (str "panel-" (.-name p))
                mfn (.-mount-fn p)]
            (str "  const panel_" ref " = document.createElement('div');\n"
                 "  panel_" ref ".id = " (q dom-id) ";\n"
                 "  panel_" ref ".className = 'wake-panel';\n"
                 "  " parent-var ".appendChild(panel_" ref ");\n"
                 "  { const _fn = " (q mfn) " ? _wakeResolve(" (q mfn) ") : null;\n"
                 "    if (typeof _fn === 'function') { try { _fn({ el: panel_" ref ", wake: window.wake || null }); } catch (err) { console.error('wake: panel mount threw:', err); } }\n"
                 "    else if (" (q mfn) ") console.warn('wake: panel mount fn not found:', " (q mfn) "); }\n")))
          panels) ""))))

;; --- Compiled per-attribute update paths ---

(defn gen-update-fns [(columns :- Any) (search-cols :- Any) (overview-fields :- Any)
                      (subtitle-field :- Any) (persist-key :- Any) (related-tab-keys :- Any)
                      (derived-attrs :- Any) (store-name :- String) (is-server :- Bool)] :- String
  (let [search-text-expr (str "[" (.join (mapv (fn [c] (str "entity." c " || ''")) search-cols) ", ") "].join(' ').toLowerCase()")
        attr-fns (.join
          (mapv (fn [col]
            (let [is-search (.includes search-cols col)
                  is-title (= col "name")
                  is-subtitle (and (not (nil? subtitle-field)) (= col subtitle-field))
                  is-overview (.includes overview-fields col)
                  needs-detail (or is-overview is-title is-subtitle)
                  ;; Derived fields that depend on this column
                  affected-derived (filterv (fn [da]
                    (.includes (.-deps da) col))
                    derived-attrs)
                  needs-entity (or is-search (> (count affected-derived) 0))
                  ;; Row-level derived recomputation
                  row-derived (.join
                    (mapv (fn [da]
                      (let [dname (id->ref (.-name da))
                            expr (.-expr da)
                            subst (assoc {} col "value")]
                        (str "      rowEntry.cells." dname ".textContent = " (compile-derived-expr expr subst) ";")))
                      affected-derived)
                    "\n")
                  ;; Detail-level derived recomputation
                  detail-derived (.join
                    (mapv (fn [da]
                      (let [dname (id->ref (.-name da))
                            expr (.-expr da)
                            subst (assoc {} col "value")]
                        (str "      if (detailNodes.field_" dname ") detailNodes.field_" dname ".textContent = " (compile-derived-expr expr subst) ";")))
                      affected-derived)
                    "\n")]

              (str "  " col "(eid, value) {\n"
                   "    const rowEntry = rowEls.get(eid);\n"
                   (if needs-entity (str "    const entity = " store-name ".get(eid);\n") "")
                   "    if (rowEntry) {\n"
                   "      rowEntry.cells." col ".textContent = value;\n"
                   (if is-search (str "      rowEntry.searchText = " search-text-expr ";\n") "")
                   (if (> (count affected-derived) 0) (str row-derived "\n") "")
                   "    }\n"
                   (if needs-detail
                     (str "    if (selectedContact === eid) {\n"
                          (if is-overview (str "      detailNodes.field_" col ".textContent = value;\n") "")
                          (if is-title "      detailNodes.title.textContent = value;\n" "")
                          (if is-subtitle "      detailNodes.subtitle.textContent = value;\n" "")
                          (if (and is-title (> (count related-tab-keys) 0))
                            (.join
                              (mapv (fn [key]
                                (str "      detailNodes." key "Header.textContent = '" (titlecase key) " for ' + value;"))
                                related-tab-keys)
                              "\n")
                            "")
                          (if (> (count affected-derived) 0) (str "\n" detail-derived "\n") "")
                          "    }\n")
                     "")
                   (if is-search "    filterRows();\n" "")
                   (cond is-server (str "    syncToServer('" store-name "', { type: 'update', eid, attr: '" col "', 'new': value });\n")
                         (not (nil? persist-key)) "    saveDb();\n"
                         :else "")
                   "  }")))
            columns)
          ",\n")]
    (str "const updateAttr = {\n" attr-fns "\n};\n")))

;; --- Undo/Redo ---

(defn gen-undo-redo [] :- String
  (.join
    ["const undoStack = [];"
     "const redoStack = [];"
     "let undoing = false;"
     "let txBuffer = null;"
     ""
     "function recordUndo(entry) {"
     "  if (undoing) return;"
     "  if (txBuffer) { txBuffer.push(entry); return; }"
     "  undoStack.push(entry);"
     "  redoStack.length = 0;"
     "}"
     ""
     "function beginTransaction() { txBuffer = []; }"
     "function commitTransaction() {"
     "  if (txBuffer && txBuffer.length > 0) {"
     "    undoStack.push({ type: 'batch', ops: txBuffer });"
     "    redoStack.length = 0;"
     "  }"
     "  txBuffer = null;"
     "}"
     ""
     "function applyUndo(op) {"
     "  if (op.type === 'update') op.store.update(op.eid, op.attr, op.old);"
     "  if (op.type === 'add') op.store.remove(op.eid);"
     "  if (op.type === 'remove') op.store.addBack(op.entity);"
     "}"
     "function applyRedo(op) {"
     "  if (op.type === 'update') op.store.update(op.eid, op.attr, op['new']);"
     "  if (op.type === 'add') op.store.addBack(op.entity);"
     "  if (op.type === 'remove') op.store.remove(op.eid);"
     "}"
     ""
     "function undo() {"
     "  const entry = undoStack.pop();"
     "  if (!entry) return;"
     "  redoStack.push(entry);"
     "  undoing = true;"
     "  if (entry.type === 'batch') {"
     "    for (let i = entry.ops.length - 1; i >= 0; i--) applyUndo(entry.ops[i]);"
     "  } else {"
     "    applyUndo(entry);"
     "  }"
     "  undoing = false;"
     "}"
     ""
     "function redo() {"
     "  const entry = redoStack.pop();"
     "  if (!entry) return;"
     "  undoStack.push(entry);"
     "  undoing = true;"
     "  if (entry.type === 'batch') {"
     "    for (const op of entry.ops) applyRedo(op);"
     "  } else {"
     "    applyRedo(entry);"
     "  }"
     "  undoing = false;"
     "}"
     ""]
    "\n"))

;; --- Layout (DOM construction for init) ---

(defn field-info-for [(fi-list :- Any) (fname :- String)] :- Any
  (first (filterv (fn [fi] (= (.-name fi) fname)) fi-list)))

(defn gen-field-types-map [(fi-list :- Any)] :- String
  (if (or (nil? fi-list) (= (count fi-list) 0)) "{}"
    (let [entries (filterv (fn [fi] (not (= (.-kind fi) "text"))) fi-list)
          parts (mapv (fn [fi]
            (let [name (.-name fi)
                  kind (.-kind fi)
                  opts (.-options fi)
                  opts-str (if (= (count opts) 0) "[]"
                    (str "[" (.join (mapv (fn [o] (q o)) opts) ", ") "]"))]
              (str (q name) ": { kind: " (q kind) ", options: " opts-str " }")))
            entries)]
      (str "{ " (.join parts ", ") " }"))))

(defn gen-layout [(en :- String) (form :- Any) (title :- String)] :- Any
  (let [form-name (.-name form)
        fields (.-fields form)
        required (.-required form)
        submit-label (.-label form)
        field-info (.-field-info form)]
    ;; Build form fields, threading counter
    (loop [i 0 c 2 code "" refs []]
      (if (>= i (count fields))
        ;; All fields done. Build submit button + split pane.
        (let [btn (+ c 1)
              split (+ c 2)
              left (+ c 3)
              hdr (+ c 4)
              h1v (+ c 5)
              srch (+ c 6)
              stat (+ c 7)
              lst (+ c 8)
              dtl (+ c 9)

              search-id (str "ld-" en "-search")
              stats-id (str "ld-" en "-stats")
              list-id (str "ld-" en "-list")
              detail-id (str "ld-" en "-detail")
              form-id (str "form-" form-name)

              rest-code (str
                ;; Submit button
                "  const el_" btn " = document.createElement(\"button\");\n"
                "  el_" btn ".className = \"px-4 py-2 bg-primary text-primary-foreground rounded-md text-sm font-medium hover:opacity-90\";\n"
                "  el_" btn ".type = \"submit\";\n"
                "  el_" btn ".textContent = " (q submit-label) ";\n"
                "  el_2.appendChild(el_" btn ");\n"
                "  el_1.appendChild(el_2);\n"
                ;; Split pane
                "  const el_" split " = document.createElement(\"div\");\n"
                "  el_" split ".className = \"flex flex-1 min-h-0\";\n"
                ;; Left pane
                "  const el_" left " = document.createElement(\"div\");\n"
                "  el_" left ".className = \"flex flex-col w-1/2 border-r border-border\";\n"
                ;; Search header
                "  const el_" hdr " = document.createElement(\"div\");\n"
                "  el_" hdr ".className = \"p-4 border-b border-border\";\n"
                ;; Title
                "  const el_" h1v " = document.createElement(\"h1\");\n"
                "  el_" h1v ".className = \"text-lg font-semibold text-foreground mb-3\";\n"
                "  el_" h1v ".textContent = " (q title) ";\n"
                "  el_" hdr ".appendChild(el_" h1v ");\n"
                ;; Search input
                "  const el_" srch " = document.createElement(\"input\");\n"
                "  el_" srch ".placeholder = \"Search...\";\n"
                "  el_" srch ".id = " (q search-id) ";\n"
                "  el_" srch ".className = \"w-full px-3 py-2 border border-border rounded-md bg-background text-foreground text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring\";\n"
                "  el_" srch ".type = \"text\";\n"
                "  el_" hdr ".appendChild(el_" srch ");\n"
                ;; Stats
                "  const el_" stat " = document.createElement(\"div\");\n"
                "  el_" stat ".id = " (q stats-id) ";\n"
                "  el_" stat ".className = \"mt-2 text-xs text-muted-foreground\";\n"
                "  el_" stat ".textContent = \"\";\n"
                "  el_" hdr ".appendChild(el_" stat ");\n"
                "  el_" left ".appendChild(el_" hdr ");\n"
                ;; List
                "  const el_" lst " = document.createElement(\"div\");\n"
                "  el_" lst ".id = " (q list-id) ";\n"
                "  el_" lst ".className = \"flex-1 overflow-y-auto\";\n"
                "  el_" left ".appendChild(el_" lst ");\n"
                "  el_" split ".appendChild(el_" left ");\n"
                ;; Detail
                "  const el_" dtl " = document.createElement(\"div\");\n"
                "  el_" dtl ".id = " (q detail-id) ";\n"
                "  el_" dtl ".className = \"w-1/2 overflow-y-auto\";\n"
                "  el_" split ".appendChild(el_" dtl ");\n"
                "  el_1.appendChild(el_" split ");\n"
                "  root.appendChild(el_1);\n")

              full-code (str
                "  const el_1 = document.createElement(\"div\");\n"
                "  el_1.className = \"flex flex-col h-screen\";\n"
                "  const el_2 = document.createElement(\"form\");\n"
                "  el_2.id = " (q form-id) ";\n"
                "  el_2.className = \"flex flex-col gap-3 p-4\";\n"
                code
                rest-code)

              ;; Refs in reverse order (matching Racket cons behavior)
              all-refs (.reverse
                (.concat
                  [(->LayoutRef detail-id (str "el_" dtl))
                   (->LayoutRef list-id (str "el_" lst))
                   (->LayoutRef stats-id (str "el_" stat))
                   (->LayoutRef search-id (str "el_" srch))]
                  (.reverse refs)
                  [(->LayoutRef form-id "el_2")]))]
          (->LayoutResult full-code all-refs))

        ;; Build one form field
        (let [field (nth fields i)
              is-req (.includes required field)
              fid (str "form-" form-name "-" field)
              fi (field-info-for field-info field)
              kind (if (nil? fi) "text" (.-kind fi))
              options (if (nil? fi) [] (.-options fi))
              d (+ c 1)
              l (+ c 2)
              inp (+ c 3)
              input-css "px-3 py-2 border border-input rounded-md bg-background text-foreground text-sm"
              input-code (cond
                (= kind "select")
                  (str
                    "  const el_" inp " = document.createElement(\"select\");\n"
                    (if is-req (str "  el_" inp ".required = true;\n") "")
                    "  el_" inp ".id = " (q fid) ";\n"
                    "  el_" inp ".className = " (q input-css) ";\n"
                    "  el_" inp ".name = " (q fid) ";\n"
                    "  { const _ph = document.createElement('option'); _ph.value = ''; _ph.textContent = " (q (str "Select " (titlecase field))) "; el_" inp ".appendChild(_ph); }\n"
                    (.join (mapv (fn [opt]
                      (str "  { const _o = document.createElement('option'); _o.value = " (q opt) "; _o.textContent = " (q (titlecase opt)) "; el_" inp ".appendChild(_o); }\n"))
                      options) ""))
                (= kind "checkbox")
                  (str
                    "  const el_" inp " = document.createElement(\"input\");\n"
                    "  el_" inp ".type = \"checkbox\";\n"
                    "  el_" inp ".id = " (q fid) ";\n"
                    "  el_" inp ".className = \"h-4 w-4 rounded border-input\";\n"
                    "  el_" inp ".name = " (q fid) ";\n")
                :else
                  (str
                    "  const el_" inp " = document.createElement(\"input\");\n"
                    (if (not (= kind "text")) (str "  el_" inp ".type = " (q kind) ";\n") "")
                    (if is-req (str "  el_" inp ".required = true;\n") "")
                    "  el_" inp ".placeholder = " (q (titlecase field)) ";\n"
                    "  el_" inp ".id = " (q fid) ";\n"
                    "  el_" inp ".className = " (q input-css) ";\n"
                    "  el_" inp ".name = " (q fid) ";\n"))
              field-code (str
                "  const el_" d " = document.createElement(\"div\");\n"
                "  el_" d ".className = " (q (if (= kind "checkbox") "flex items-center gap-2" "flex flex-col gap-1")) ";\n"
                "  const el_" l " = document.createElement(\"label\");\n"
                "  el_" l ".htmlFor = " (q fid) ";\n"
                "  el_" l ".className = \"text-xs font-medium uppercase text-muted-foreground\";\n"
                "  el_" l ".textContent = " (q (titlecase field)) ";\n"
                (if (= kind "checkbox")
                  (str input-code "  el_" d ".appendChild(el_" inp ");\n"
                       "  el_" d ".appendChild(el_" l ");\n")
                  (str "  el_" d ".appendChild(el_" l ");\n" input-code
                       "  el_" d ".appendChild(el_" inp ");\n"))
                "  el_2.appendChild(el_" d ");\n")]
          (recur (+ i 1) (+ c 3)
                 (str code field-code)
                 (conj refs (->LayoutRef fid (str "el_" inp)))))))))

;; --- Ref declarations ---

(defn gen-ref-decls [(refs :- Any)] :- String
  (.join (mapv (fn [r] (str "let " (id->ref (.-id r)) ";")) refs) "\n"))

(defn gen-ref-assigns [(refs :- Any)] :- String
  (.join (mapv (fn [r] (str "  " (id->ref (.-id r)) " = " (.-vname r) ";")) refs) "\n"))

;; --- Init function ---

(defn gen-init-fn [(en :- String) (form-name :- String) (store-name :- String)
                   (related-info :- Any) (persist-key :- Any) (is-server :- Bool) (layout-result :- Any)] :- String
  (let [form-ref (id->ref (str "form-" form-name))
        search-ref (id->ref (str "ld-" en "-search"))
        ref-assigns (gen-ref-assigns (.-refs layout-result))
        related-watchers (.join
          (mapv (fn [ri]
            (let [rel-store (.-store ri)
                  key (.-key ri)
                  render-fn (str "render" (titlecase key))]
              (str "  " rel-store ".watch((evt) => {\n"
                   "    if (evt.type === 'add' || evt.type === 'load' || evt.type === 'remove') " render-fn "();\n"
                   "    if (evt.type === 'add') {\n"
                   "      recordUndo({ type: 'add', store: " rel-store ", eid: evt.eid, entity: evt.entity });\n"
                   (cond is-server (str "      syncToServer('" rel-store "', evt);\n")
                         (not (nil? persist-key)) "      saveDb();\n"
                         :else "")
                   "    }\n"
                   "    if (evt.type === 'remove') {\n"
                   "      recordUndo({ type: 'remove', store: " rel-store ", eid: evt.eid, entity: evt.entity });\n"
                   (cond is-server (str "      syncToServer('" rel-store "', evt);\n")
                         (not (nil? persist-key)) "      saveDb();\n"
                         :else "")
                   "    }\n"
                   "  });\n")))
            related-info)
          "\n")]
    (str
      (if is-server "async function init() {\n" "function init() {\n")
      "  const root = document.getElementById(window.WAKE_MOUNT_ID || 'app');\n"
      "\n"
      (.-code layout-result) "\n"
      "\n"
      ref-assigns "\n"
      "\n"
      "  buildDetailPanel();\n"
      "\n"
      "  " form-ref ".addEventListener('submit', handleSubmit);\n"
      "  " search-ref ".addEventListener('input', filterRows);\n"
      "\n"
      "  " store-name ".watch((evt) => {\n"
      "    if (evt.type === 'add') {\n"
      "      addRow(evt.entity);\n"
      "      filterRows();\n"
      "      " (id->ref en) "Count++;\n"
      "      updateStats();\n"
      "      recordUndo({ type: 'add', store: " store-name ", eid: evt.eid, entity: evt.entity });\n"
      (cond is-server (str "      syncToServer('" store-name "', evt);\n")
            (not (nil? persist-key)) "      saveDb();\n"
            :else "")
      "    }\n"
      "    if (evt.type === 'load') {\n"
      "      rebuildList();\n"
      "      " (id->ref en) "Count = " store-name ".all().length;\n"
      "      updateStats();\n"
      "      renderDetail();\n"
      "    }\n"
      "    if (evt.type === 'update') {\n"
      "      const fn = updateAttr[evt.attr];\n"
      "      if (fn) fn(evt.eid, evt.new || '');\n"
      "      recordUndo({ type: 'update', store: " store-name ", eid: evt.eid, attr: evt.attr, old: evt.old, 'new': evt.new });\n"
      "    }\n"
      "    if (evt.type === 'remove') {\n"
      "      removeRow(evt.eid);\n"
      "      " (id->ref en) "Count--;\n"
      "      updateStats();\n"
      "      recordUndo({ type: 'remove', store: " store-name ", eid: evt.eid, entity: evt.entity });\n"
      "      if (selectedContact === evt.eid) selectContact(null);\n"
      (cond is-server (str "      syncToServer('" store-name "', evt);\n")
            (not (nil? persist-key)) "      saveDb();\n"
            :else "")
      "    }\n"
      "  });\n"
      "\n"
      related-watchers "\n"
      "  document.addEventListener('keydown', (e) => {\n"
      "    if ((e.ctrlKey || e.metaKey) && e.key === 'z' && !e.shiftKey) { e.preventDefault(); undo(); }\n"
      "    if ((e.ctrlKey || e.metaKey) && e.key === 'z' && e.shiftKey) { e.preventDefault(); redo(); }\n"
      "  });\n"
      "\n"
      (cond is-server "  await loadFromServer();\n"
            (not (nil? persist-key)) "  restoreDb();\n"
            :else "")
      "  updateStats();\n"
      "  renderDetail();\n"
      "}\n")))

;; === Component-based codegen ===

;; An IrAction → a JS statement.
;;  (tell pred val)     → REMOTE claim write: POST /api/tell {graph,id,pred,obj}.
;;                        The daemon commits → /live push → feed re-fetch → re-render.
;;                        Uses props.id (the claim ref) + window.WAKE_GRAPH. No store needed.
;;  (assert/set pred v) → LOCAL store mutation (update = supersede on a claim store).
;;  (retract)           → LOCAL store.remove (tombstone).
;; tell is the claims-native round-trip; assert/set/retract are local-optimistic.
(defn compile-action [(action :- Any) (store-name :- String)] :- String
  (if (nil? action) ""
    (let [verb (.-verb action)
          args (.-args action)
          argval (fn [a]
                   (if (= (get a "kind") "literal") (q (get a "value"))
                     (str "props." (get a "name"))))
          local? (or (= store-name "") (nil? store-name))]
      (cond
        (= verb "tell")
          (if (>= (count args) 2)
            (str "fetch('/api/tell',{method:'POST',headers:{'Content-Type':'application/json'},"
                 "body:JSON.stringify({graph:(window.WAKE_GRAPH||'board'),id:props.id,pred:"
                 (q (get (nth args 0) "name")) ",obj:" (argval (nth args 1)) "})});")
            "")
        (and (not local?) (or (= verb "assert") (= verb "set")))
          (if (>= (count args) 2)
            (str store-name ".update(props.eid, " (q (get (nth args 0) "name")) ", " (argval (nth args 1)) ");")
            "")
        (and (not local?) (= verb "retract"))
          (str store-name ".remove(props.eid);")
        :else ""))))

(defn gen-when-block! [(node :- Any) (counter :- Any) (parent-var :- String) (props :- Any) (store-name :- String)] :- Any
  (let [prop (.-prop node)
        wc (get counter "n")
        when-var (str "when_" wc)
        anchor-var (str "whenAnchor_" wc)]
    (set! (.-n counter) (+ wc 1))
    (let [child-results (mapv (fn [el] (gen-element! el counter props store-name)) (.-children node))
          child-code (.join (mapv (fn [cr] (.-code cr)) child-results) "")
          child-appends (.join
            (mapv (fn [cr] (str "      " parent-var ".insertBefore(" (.-vname cr) ", " anchor-var ");\n"))
              child-results) "")
          child-vars (mapv (fn [cr] (.-vname cr)) child-results)]
      (->RenderResult
        (str "  const " anchor-var " = document.createComment('when:" prop "');\n"
             "  " parent-var ".appendChild(" anchor-var ");\n"
             "  let " when-var " = [];\n"
             "  function " when-var "_update(condition) {\n"
             "    if (condition && " when-var ".length === 0) {\n"
             child-code
             child-appends
             "      " when-var " = [" (.join child-vars ", ") "];\n"
             "    } else if (!condition && " when-var ".length > 0) {\n"
             "      for (const el of " when-var ") el.remove();\n"
             "      " when-var " = [];\n"
             "    }\n"
             "  }\n"
             "  " when-var "_update(props." prop ");\n")
        ""
        [(->Binding prop (str when-var "_update") "_when")]))))

(defn gen-element! [(el :- Any) (counter :- Any) (props :- Any) (store-name :- String)] :- Any
  (if (not (nil? (.-prop el)))
    nil
    (let [c (get counter "n")
          var-name (str "el_" c)
          tag (.-tag el)
          attrs (.-attrs el)
          children (.-children el)]
      (set! (.-n counter) (+ c 1))
      (let [cls-attr (get attrs "class")
            text-attr (get attrs "text")
            placeholder-attr (get attrs "placeholder")
            type-attr (get attrs "type")
            cls-line (if (nil? cls-attr) ""
                      (str "  " var-name ".className = " (q (get cls-attr "value")) ";\n"))
            text-line (if (nil? text-attr) ""
                       (if (= (get text-attr "type") "bind")
                         (str "  " var-name ".textContent = props." (get text-attr "prop") " || '';\n")
                         (str "  " var-name ".textContent = " (q (get text-attr "value")) ";\n")))
            placeholder-line (if (nil? placeholder-attr) ""
                              (str "  " var-name ".placeholder = " (q (get placeholder-attr "value")) ";\n"))
            type-line (if (nil? type-attr) ""
                       (str "  " var-name ".type = " (q (get type-attr "value")) ";\n"))
            action-lines (.join
              (mapv (fn [k]
                      (let [a (get attrs k)]
                        (str "  " var-name ".addEventListener(" (q (get a "event"))
                             ", (ev) => { ev.preventDefault(); " (compile-action (get a "action") store-name) " });\n")))
                (filterv (fn [k] (= (get (get attrs k) "type") "action")) (keys attrs)))
              "")
            bindings (if (and (not (nil? text-attr)) (= (get text-attr "type") "bind"))
                      [(->Binding (get text-attr "prop") var-name "textContent")]
                      [])
            when-children (filterv (fn [child] (not (nil? (.-prop child)))) children)
            element-children (filterv (fn [child] (nil? (.-prop child))) children)
            child-results (mapv (fn [child] (gen-element! child counter props store-name)) element-children)
            child-code (.join (mapv (fn [cr] (.-code cr)) child-results) "")
            child-appends (.join
              (mapv (fn [cr] (str "  " var-name ".appendChild(" (.-vname cr) ");\n"))
                child-results) "")
            when-results (mapv (fn [wc] (gen-when-block! wc counter var-name props store-name)) when-children)
            when-code (.join (mapv (fn [wr] (.-code wr)) when-results) "")
            child-bindings (reduce (fn [acc cr] (into acc (.-bindings cr))) bindings child-results)
            all-bindings (reduce (fn [acc wr] (into acc (.-bindings wr))) child-bindings when-results)]
        (->RenderResult
          (str "  const " var-name " = document.createElement(" (q tag) ");\n"
               cls-line text-line placeholder-line type-line action-lines
               child-code child-appends when-code)
          var-name
          all-bindings)))))

(defn gen-component-fn! [(comp :- Any) (store-name :- String)] :- String
  (let [name (.-name comp)
        props (.-props comp)
        body (.-body comp)
        fn-name (str (id->ref name) "_create")
        counter {"n" 0}
        root-results (mapv (fn [el] (gen-element! el counter props store-name)) body)
        root-code (.join (mapv (fn [r] (.-code r)) root-results) "")
        all-bindings (reduce (fn [acc r] (into acc (.-bindings r))) [] root-results)
        root-var (if (= (count root-results) 1)
                   (.-vname (nth root-results 0))
                   (let [wrapper-var (str "el_" (.-n counter))]
                     (set! (.-n counter) (+ (.-n counter) 1))
                     wrapper-var))
        needs-wrapper (> (count root-results) 1)
        wrapper-code (if needs-wrapper
                       (str "  const " root-var " = document.createElement('div');\n"
                            (.join (mapv (fn [r] (str "  " root-var ".appendChild(" (.-vname r) ");\n")) root-results) ""))
                       "")
        update-fns (.join
          (mapv (fn [b]
            (if (= (.-dom-prop b) "_when")
              (str "    " (.-prop b) "(v) { " (.-vname b) "(v); }")
              (str "    " (.-prop b) "(v) { " (.-vname b) "." (.-dom-prop b) " = v; }")))
            all-bindings)
          ",\n")
        text-bindings (filterv (fn [b] (not (= (.-dom-prop b) "_when"))) all-bindings)
        nodes-entries (.join
          (mapv (fn [b] (str "    " (.-prop b) ": " (.-vname b))) text-bindings)
          ",\n")]
    (str "function " fn-name "(props) {\n"
         root-code
         wrapper-code
         "  return {\n"
         "    el: " root-var ",\n"
         "    update: {\n" update-fns "\n    },\n"
         "    nodes: {\n" nodes-entries "\n    },\n"
         "    destroy() { " root-var ".remove(); }\n"
         "  };\n"
         "}\n")))

(defn gen-view-program! [(prog :- Any)] :- String
  (let [g (graph/check-program prog)
        components (or (.-components prog) [])
        view (first (or (.-views prog) []))
        en (.-entity-name view)
        ge (first (filterv (fn [e] (= (.-name e) en)) (.-entities g)))
        store-name (.-store-name ge)
        comp-name (.-component view)
        comp (first (filterv (fn [c] (= (.-name c) comp-name)) components))
        add-fields (.-add-fields view)
        title (.-title view)
        panels (or (.-panels prog) [])
        persist (.-persist g)
        raw-persist-key (if (nil? persist) nil (.-key persist))
        persist-mode (if (nil? persist) nil (.-storage persist))
        is-server (= persist-mode "server")
        is-feed (= persist-mode "feed")
        feed-url (if is-feed raw-persist-key nil)
        ;; identity field for per-row feed diffing: prefer a field marked :unique identity,
        ;; else the first unique field, else nil (runtime falls back to whole-store replace).
        feed-uniques (if is-feed (.-unique-fields ge) [])
        feed-id-field (let [ids (filterv (fn [f] (= (.-unique f) "identity")) feed-uniques)]
                        (cond
                          (not (empty? ids)) (.-name (first ids))
                          (not (empty? feed-uniques)) (.-name (first feed-uniques))
                          :else nil))
        ;; nil out persist-key under feed so the localStorage saveDb/restoreDb branches go dark.
        persist-key (if is-feed nil raw-persist-key)
        src-name (.-ns g)
        fn-name (str (id->ref comp-name) "_create")
        has-select (not (nil? (.-select-component view)))
        select-comp (if has-select
                      (first (filterv (fn [c] (= (.-name c) (.-select-component view))) components))
                      nil)
        select-fn-name (if has-select (str (id->ref (.-name select-comp)) "_create") nil)
        form-fields-code (.join
          (mapv (fn [f]
            (let [fid (str "form_" (id->ref f))]
              (str "  const " fid "_label = document.createElement('label');\n"
                   "  " fid "_label.className = 'text-xs font-medium uppercase text-muted-foreground';\n"
                   "  " fid "_label.textContent = " (q (titlecase f)) ";\n"
                   "  formEl.appendChild(" fid "_label);\n"
                   "  const " fid " = document.createElement('input');\n"
                   "  " fid ".className = 'px-3 py-2 border border-input rounded-md bg-background text-foreground text-sm';\n"
                   "  " fid ".placeholder = " (q (titlecase f)) ";\n"
                   "  formEl.appendChild(" fid ");\n")))
            add-fields) "")
        add-obj (.join (mapv (fn [f] (str (id->ref f) ": form_" (id->ref f) ".value.trim()")) add-fields) ", ")
        clear-lines (.join (mapv (fn [f] (str "    form_" (id->ref f) ".value = '';")) add-fields) "\n")

        init-open #r#"
          function init() {
            const root = document.getElementById(window.WAKE_MOUNT_ID || 'app');
            const container = document.createElement('div');
            container.className = 'flex flex-col h-screen';

            const formEl = document.createElement('form');
            formEl.className = 'flex flex-col gap-3 p-4';
          "#

        submit-btn #r#"
            const submitBtn = document.createElement('button');
            submitBtn.type = 'submit';
            submitBtn.className = 'px-4 py-2 bg-primary text-primary-foreground rounded-md text-sm font-medium hover:opacity-90';
            submitBtn.textContent = 'Add';
            formEl.appendChild(submitBtn);
          "#

        header-and-list #r#"
            const headerEl = document.createElement('div');
            headerEl.className = 'p-4 border-b border-border';
            const titleEl = document.createElement('h1');
            titleEl.className = 'text-lg font-semibold text-foreground';
          "#

        select-setup-top #r#"
            const statsEl = document.createElement('div');
            statsEl.className = 'mt-2 text-xs text-muted-foreground';
            headerEl.appendChild(statsEl);
            const listEl = document.createElement('div');
            listEl.className = 'flex-1 overflow-y-auto';
            const splitPane = document.createElement('div');
            splitPane.className = 'flex flex-1 min-h-0';
            const leftPane = document.createElement('div');
            leftPane.className = 'flex flex-col w-1/2 min-h-0 border-r border-border';
            leftPane.appendChild(headerEl);
            leftPane.appendChild(listEl);
            splitPane.appendChild(leftPane);
            const rightPane = document.createElement('div');
            rightPane.className = 'w-1/2 min-h-0 overflow-y-auto';
            const detailEmpty = document.createElement('div');
            detailEmpty.className = 'flex items-center justify-center h-full text-muted-foreground text-sm';
            detailEmpty.textContent = 'Select an item to view details';
            rightPane.appendChild(detailEmpty);
            splitPane.appendChild(rightPane);
            container.appendChild(splitPane);
            root.appendChild(container);
            let selectedEid = null;
            let detailInst = null;
            function selectItem(eid) {
              selectedEid = eid;
              // Push selection onto the shared bus (IDENTITY, not eid) so custom panes
              // (Cytoscape/stream) highlight in lockstep. Guarded: no-op when no feed bus.
              if (typeof _wakePushSelection === 'function') _wakePushSelection(eid);
              if (detailInst) { detailInst.destroy(); detailInst = null; }
              if (eid === null) { detailEmpty.style.display = ''; return; }
              detailEmpty.style.display = 'none';
          "#
        select-setup-bottom #r#"
              rightPane.appendChild(detailInst.el);
            }
            const instances = new Map();
          "#
        list-setup-no-select #r#"
            const statsEl = document.createElement('div');
            statsEl.className = 'mt-2 text-xs text-muted-foreground';
            headerEl.appendChild(statsEl);
            container.appendChild(headerEl);

            const listEl = document.createElement('div');
            listEl.className = 'flex-1 overflow-y-auto';
            container.appendChild(listEl);
            root.appendChild(container);

            const instances = new Map();
          "#
        list-setup (if has-select
                     (str select-setup-top "\n"
                          "      const entity = " store-name ".get(eid);\n"
                          "      if (!entity) return;\n"
                          "      detailInst = " select-fn-name "(entity);\n"
                          select-setup-bottom)
                     list-setup-no-select)

        watcher-update #r#"
              if (evt.type === 'update') {
                const inst = instances.get(evt.eid);
                if (inst && inst.update[evt.attr]) inst.update[evt.attr](evt.new || '');
          "#

        keyboard-handler #r#"
            document.addEventListener('keydown', (e) => {
              if ((e.ctrlKey || e.metaKey) && e.key === 'z' && !e.shiftKey) { e.preventDefault(); undo(); }
              if ((e.ctrlKey || e.metaKey) && e.key === 'z' && e.shiftKey) { e.preventDefault(); redo(); }
            });
          "#
        ]

    (str
      "// Generated by wake — semantic UI compiler\n"
      "// Source: " src-name "\n"
      "// This file is a build artifact. Edit the .wake source, not this file.\n\n"
      "(function() {\n"
      "'use strict';\n\n"

      ;; Inlined value-equality runtime (backs the store change-gate).
      (gen-equiv-runtime) "\n"

      "// ── Store ──────────────────────────────────────────\n"
      (if (= persist-mode "claims") (gen-store-claims store-name []) (gen-store store-name [])) "\n\n"

      "// ── Component ────────────────────────────────────────\n"
      (gen-component-fn! comp store-name) "\n"

      (if has-select
        (str "// ── Detail Component ─────────────────────────────────\n"
             (gen-component-fn! select-comp store-name) "\n")
        "")

      "// ── Undo / Redo ─────────────────────────────────────\n"
      (gen-undo-redo) "\n"

      (cond
        (not (nil? persist-key))
          (str "// ── Persistence ──────────────────────────────────────\n"
               (gen-persistence persist-key [store-name]) "\n")
        is-feed
          (str "// ── Live external feed ───────────────────────────────\n"
               (gen-feed-persistence feed-url store-name feed-id-field) "\n")
        :else "")

      "// ── Init ─────────────────────────────────────────────\n"
      (if is-server (.replace init-open "function init()" "async function init()") init-open) "\n"
      (gen-theme-style (.-theme prog))
      form-fields-code
      submit-btn "\n"
      "  formEl.addEventListener('submit', (e) => {\n"
      "    e.preventDefault();\n"
      "    const first = form_" (id->ref (nth add-fields 0)) ".value.trim();\n"
      "    if (!first) return;\n"
      "    " store-name ".add({ " add-obj " });\n"
      clear-lines "\n"
      "  });\n"
      "  container.appendChild(formEl);\n\n"

      header-and-list "\n"
      "  titleEl.textContent = " (q title) ";\n"
      "  headerEl.appendChild(titleEl);\n"
      list-setup "\n\n"

      (gen-panels-mount panels "container")

      "  " store-name ".watch((evt) => {\n"
      "    if (evt.type === 'add') {\n"
      "      const inst = " fn-name "(evt.entity);\n"
      "      inst.el.className = (inst.el.className || '') + ' cursor-pointer hover:bg-muted/50';\n"
      "      listEl.appendChild(inst.el);\n"
      "      instances.set(evt.eid, inst);\n"
      (if has-select "      inst.el.addEventListener('click', () => selectItem(evt.eid));\n" "")
      "      statsEl.textContent = 'Total: ' + instances.size;\n"
      "      recordUndo({ type: 'add', store: " store-name ", eid: evt.eid, entity: evt.entity });\n"
      (cond is-server (str "      syncToServer('" store-name "', evt);\n")
            (not (nil? persist-key)) "      saveDb();\n"
            :else "")
      "    }\n"
      watcher-update "\n"
      (if has-select "      if (selectedEid === evt.eid && detailInst && detailInst.update[evt.attr]) detailInst.update[evt.attr](evt.new || '');\n" "")
      "      recordUndo({ type: 'update', store: " store-name ", eid: evt.eid, attr: evt.attr, old: evt.old, 'new': evt.new });\n"
      (cond is-server (str "      syncToServer('" store-name "', evt);\n")
            (not (nil? persist-key)) "      saveDb();\n"
            :else "")
      "    }\n"
      "    if (evt.type === 'remove') {\n"
      "      const inst = instances.get(evt.eid);\n"
      "      if (inst) { inst.destroy(); instances.delete(evt.eid); }\n"
      "      statsEl.textContent = 'Total: ' + instances.size;\n"
      (if has-select "      if (selectedEid === evt.eid) selectItem(null);\n" "")
      "      recordUndo({ type: 'remove', store: " store-name ", eid: evt.eid, entity: evt.entity });\n"
      (cond is-server (str "      syncToServer('" store-name "', evt);\n")
            (not (nil? persist-key)) "      saveDb();\n"
            :else "")
      "    }\n"
      "    if (evt.type === 'load') {\n"
      "      listEl.innerHTML = '';\n"
      "      instances.clear();\n"
      (if has-select "      if (selectedEid) selectItem(null);\n" "")
      "      for (const entity of " store-name ".all()) {\n"
      "        const inst = " fn-name "(entity);\n"
      "        inst.el.className = (inst.el.className || '') + ' cursor-pointer hover:bg-muted/50';\n"
      (if has-select "        inst.el.addEventListener('click', () => selectItem(entity.eid));\n" "")
      "        listEl.appendChild(inst.el);\n"
      "        instances.set(entity.eid, inst);\n"
      "      }\n"
      "      statsEl.textContent = 'Total: ' + instances.size;\n"
      "    }\n"
      "  });\n\n"

      keyboard-handler "\n\n"
      (cond is-server "  await loadFromServer();\n"
            (not (nil? persist-key)) "  restoreDb();\n"
            is-feed "  startFeed();\n"
            :else "")
      "}\n\n"
      "init();\n"
      "})();\n")))

;; === Multi-view routing codegen ===

(defn gen-view-section [(view :- Any) (components :- Any) (ge :- Any) (store-name :- String) (is-server :- Bool) (all-entities :- Any) (all-views :- Any)] :- String
  (let [comp-name (.-component view)
        fn-name (str (id->ref comp-name) "_create")
        add-fields (or (.-add-fields view) [])
        title (.-title view)
        view-name (.-name view)
        has-select (not (nil? (.-select-component view)))
        select-fn-name (if has-select (str (id->ref (.-select-component view)) "_create") nil)
        has-form (> (count add-fields) 0)
        tabs (or (.-tabs view) [])
        has-tabs (and has-select is-server (> (count tabs) 0))

        lookup-fields-meta (if (and is-server has-select)
          (let [stored (.-stored-fields ge)
                lf (filterv (fn [f] (not (nil? (.-lookup-table f)))) stored)]
            (if (= (count lf) 0) nil lf))
          nil)

        view-filters (or (.-filters view) [])
        view-date-filters (or (.-date-filters view) [])
        all-stored (if is-server (.-stored-fields ge) [])
        filter-fields-meta (if (and is-server (> (count view-filters) 0))
          (filterv some? (mapv (fn [n]
            (first (filterv (fn [f] (= (.-name f) n)) all-stored)))
            view-filters))
          [])
        has-filters (> (count filter-fields-meta) 0)
        date-filter-fields-meta (if (and is-server (> (count view-date-filters) 0))
          (filterv some? (mapv (fn [n]
            (first (filterv (fn [f] (= (.-name f) n)) all-stored)))
            view-date-filters))
          [])
        has-date-filters (> (count date-filter-fields-meta) 0)

        lookup-map-js (if (some? lookup-fields-meta)
          (str "      const _lookups = {"
            (.join (mapv (fn [f]
              (str "'" (.-name f) "': '" (.-lookup-table f) "'"))
              lookup-fields-meta) ", ")
            "};\n")
          "")

        nav-map-js (if (and (some? lookup-fields-meta) (some? all-views))
          (let [nav-fields (filterv (fn [f]
                  (some? (first (filterv (fn [e] (= (.-table-name e) (.-lookup-table f))) all-entities))))
                  lookup-fields-meta)]
            (if (= (count nav-fields) 0) ""
              (str "      const _navFields = {"
                (.join (mapv (fn [f]
                  (let [target-entity (first (filterv (fn [e] (= (.-table-name e) (.-lookup-table f))) all-entities))
                        target-view (first (filterv (fn [v] (= (.-entity-name v) (.-name target-entity))) all-views))]
                    (str "'" (.-name f) "': '" (if (some? target-view) (.-name target-view) (.-store-name target-entity)) "'")))
                  nav-fields) ", ")
                "};\n")))
          "")
        form-fields (.join
          (mapv (fn [f]
            (let [fid (str "form_" (id->ref f))]
              (str "    const " fid "_label = document.createElement('label');\n"
                   "    " fid "_label.className = 'text-xs font-medium uppercase text-muted-foreground';\n"
                   "    " fid "_label.textContent = " (q (titlecase f)) ";\n"
                   "    formEl.appendChild(" fid "_label);\n"
                   "    const " fid " = document.createElement('input');\n"
                   "    " fid ".className = 'px-3 py-2 border border-input rounded-md bg-background text-foreground text-sm';\n"
                   "    " fid ".placeholder = " (q (titlecase f)) ";\n"
                   "    formEl.appendChild(" fid ");\n")))
            add-fields) "")
        add-obj (.join (mapv (fn [f] (str (id->ref f) ": form_" (id->ref f) ".value.trim()")) add-fields) ", ")
        clear-lines (.join (mapv (fn [f] (str "      form_" (id->ref f) ".value = '';")) add-fields) "\n")

        ;; Column header from row component's children
        comp (first (filterv (fn [c] (= (.-name c) comp-name)) components))
        root-el (first (.-body comp))
        col-children (filterv
          (fn [ch]
            (let [attrs (.-attrs ch)]
              (if (nil? attrs) false
                (let [ta (get attrs "text")]
                  (and (not (nil? ta)) (= (get ta "type") "bind"))))))
          (.-children root-el))
        grid-tpl (.join (mapv (fn [ch]
            (let [cls (or (get (get (.-attrs ch) "class") "value") "")
                  width-cls (first (filterv
                    (fn [c] (or (= (.indexOf c "flex-") 0) (= (.indexOf c "w-") 0)))
                    (.split cls " ")))]
              (cond
                (nil? width-cls) "2fr"
                (= width-cls "flex-1") "3fr"
                (= width-cls "w-16") "1fr"
                (= width-cls "w-20") "1.5fr"
                (= width-cls "w-24") "2fr"
                (= width-cls "w-32") "2.5fr"
                (= width-cls "w-40") "3fr"
                (= width-cls "w-48") "4fr"
                :else "2fr")))
            col-children) " ")
        col-props (mapv (fn [ch] (get (get (.-attrs ch) "text") "prop")) col-children)
        grid-tpl-sel (if is-server (str "30px " grid-tpl) grid-tpl)

        tab-stores (if has-tabs
          (mapv (fn [tab]
            (let [tab-entity-name (.-entity-name tab)
                  tab-ge (first (filterv (fn [e] (= (.-name e) tab-entity-name)) all-entities))]
              (if (nil? tab-ge) (str tab-entity-name "s") (.-store-name tab-ge))))
            tabs)
          [])

        tab-btn-code (if has-tabs
          (loop [i 0 acc ""]
            (if (>= i (count tabs))
              acc
              (let [tab (nth tabs i)
                    label (.-label tab)
                    ref (str "_tb" i)]
                (recur (+ i 1)
                  (str acc
                    "      const " ref " = document.createElement('button');\n"
                    "      " ref ".textContent = " (q label) ";\n"
                    "      " ref ".className = 'px-4 py-2 text-sm font-medium text-muted-foreground border-b-2 border-transparent hover:text-foreground';\n"
                    "      " ref ".addEventListener('click', () => _switchTab(" i "));\n"
                    "      _tabBar.appendChild(" ref ");\n"
                    "      _tabBtns.push(" ref ");\n")))))
          "")

        tab-endpoints-js (if has-tabs
          (str "[" (.join
            (loop [i 0 acc []]
              (if (>= i (count tabs))
                acc
                (recur (+ i 1)
                  (conj acc (str "'/api/" store-name "/' + eid + '/" (nth tab-stores i) "'")))))
            ", ") "]")
          "[]")

        tab-fields-js (if has-tabs
          (str "[" (.join
            (mapv (fn [tab]
              (str "[" (.join (mapv (fn [f] (str "'" f "'")) (.-display-fields tab)) ", ") "]"))
              tabs)
            ", ") "]")
          "[]")

        tab-labels-js (if has-tabs
          (str "[" (.join
            (mapv (fn [tab]
              (str "[" (.join (mapv (fn [f] (str "'" (titlecase f) "'")) (.-display-fields tab)) ", ") "]"))
              tabs)
            ", ") "]")
          "[]")

        tab-meta-js (if has-tabs
          (str "[" (.join
            (mapv (fn [tab]
              (let [fk (.-fk-column tab)
                    ent (.-entity-name tab)
                    filt (or (.-filter tab) "")
                    filt-pairs (if (= filt "") "{}"
                      (let [clean (.replace (.replace filt " " "") "  " "")
                            parts (.split clean "AND")
                            entries (mapv (fn [p]
                              (let [kv (.split (.trim p) "=")]
                                (str "'" (.trim (nth kv 0)) "': '" (.trim (nth kv 1)) "'")))
                              parts)]
                        (str "{" (.join entries ", ") "}")))]
                (str "{store:'" ent "s', fk:'" fk "', filter:" filt-pairs "}")))
              tabs)
            ", ") "]")
          "[]")

        tab-code (if has-tabs
          (str
            "      const _tabBar = document.createElement('div');\n"
            "      _tabBar.className = 'flex border-b border-border mt-4';\n"
            "      const _tabBtns = [];\n"
            "      const _tabContent = document.createElement('div');\n"
            "      _tabContent.className = 'p-4';\n"
            tab-btn-code
            "      let _activeTabIdx = -1;\n"
            "      const _tabEndpoints = " tab-endpoints-js ";\n"
            "      const _tabFields = " tab-fields-js ";\n"
            "      const _tabLabels = " tab-labels-js ";\n"
            "      const _tabMeta = " tab-meta-js ";\n"
            "      function _switchTab(idx) {\n"
            "        if (_activeTabIdx === idx) return;\n"
            "        _activeTabIdx = idx;\n"
            "        _tabBtns.forEach((b, i) => {\n"
            "          b.className = i === idx ? 'px-4 py-2 text-sm font-medium text-foreground border-b-2 border-primary' : 'px-4 py-2 text-sm font-medium text-muted-foreground border-b-2 border-transparent hover:text-foreground';\n"
            "        });\n"
            "        _tabContent.innerHTML = '<div class=\"text-sm text-muted-foreground\">Loading...</div>';\n"
            "        fetch(window.location.origin + _tabEndpoints[idx])\n"
            "          .then(r => r.json())\n"
            "          .then(rows => {\n"
            "            _tabContent.innerHTML = '';\n"
            "            const meta = _tabMeta[idx];\n"
            "            const addBtn = document.createElement('button');\n"
            "            addBtn.textContent = '+ Add';\n"
            "            addBtn.className = 'mb-2 px-3 py-1 text-xs font-medium bg-primary text-primary-foreground rounded-md hover:bg-primary/90';\n"
            "            const addForm = document.createElement('div');\n"
            "            addForm.className = 'mb-3 p-3 border border-border rounded-md bg-muted/30';\n"
            "            addForm.style.display = 'none';\n"
            "            const fields = _tabFields[idx], labels = _tabLabels[idx];\n"
            "            const inputs = {};\n"
            "            fields.forEach(f => {\n"
            "              const lbl = document.createElement('label'); lbl.className = 'text-xs font-medium uppercase text-muted-foreground block mt-1'; lbl.textContent = f;\n"
            "              const inp = document.createElement('input'); inp.className = 'w-full px-2 py-1 border border-input rounded-md bg-background text-foreground text-sm mt-0.5';\n"
            "              inputs[f] = inp; addForm.appendChild(lbl); addForm.appendChild(inp);\n"
            "            });\n"
            "            const saveBtn = document.createElement('button'); saveBtn.textContent = 'Save';\n"
            "            saveBtn.className = 'mt-2 mr-2 px-3 py-1 text-xs font-medium bg-primary text-primary-foreground rounded-md';\n"
            "            const cancelBtn = document.createElement('button'); cancelBtn.textContent = 'Cancel';\n"
            "            cancelBtn.className = 'mt-2 px-3 py-1 text-xs font-medium border border-border text-foreground rounded-md';\n"
            "            saveBtn.addEventListener('click', async () => {\n"
            "              const body = {...meta.filter}; body[meta.fk] = selectedEid;\n"
            "              for (const [k,v] of Object.entries(inputs)) body[k] = v.value;\n"
            "              await fetch(window.location.origin + '/api/' + meta.store, { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });\n"
            "              addForm.style.display = 'none'; _activeTabIdx = -1; _switchTab(idx);\n"
            "            });\n"
            "            cancelBtn.addEventListener('click', () => { addForm.style.display = 'none'; });\n"
            "            addForm.appendChild(saveBtn); addForm.appendChild(cancelBtn);\n"
            "            addBtn.addEventListener('click', () => { addForm.style.display = addForm.style.display === 'none' ? '' : 'none'; });\n"
            "            _tabContent.appendChild(addBtn); _tabContent.appendChild(addForm);\n"
            "            if (rows.length === 0) { const noRec = document.createElement('div'); noRec.className = 'text-sm text-muted-foreground py-2'; noRec.textContent = 'No records'; _tabContent.appendChild(noRec); return; }\n"
            "            const tbl = document.createElement('table');\n"
            "            tbl.className = 'w-full text-sm';\n"
            "            const thead = document.createElement('thead'), hr = document.createElement('tr');\n"
            "            labels.forEach(l => { const th = document.createElement('th'); th.className = 'text-left text-xs font-medium uppercase text-muted-foreground py-1 px-2'; th.textContent = l; hr.appendChild(th); });\n"
            "            thead.appendChild(hr); tbl.appendChild(thead);\n"
            "            const tbody = document.createElement('tbody');\n"
            "            for (const row of rows) { const tr = document.createElement('tr'); tr.className = 'border-t border-border'; fields.forEach(f => { const td = document.createElement('td'); td.className = 'py-1.5 px-2'; td.textContent = row[f] || ''; tr.appendChild(td); }); tbody.appendChild(tr); }\n"
            "            tbl.appendChild(tbody); _tabContent.appendChild(tbl);\n"
            "          });\n"
            "      }\n"
            "      _tabBarEl = _tabBar;\n"
            "      _tabContentEl = _tabContent;\n"
            "      rightPane.appendChild(_tabBar);\n"
            "      rightPane.appendChild(_tabContent);\n"
            "      _switchTab(0);\n")
          "")

        export-btn-js (if is-server
          (str
            "    const exportBtn = document.createElement('button');\n"
            "    exportBtn.textContent = 'Export CSV';\n"
            "    exportBtn.className = 'px-3 py-1 text-sm font-medium border border-border text-foreground rounded-md hover:bg-muted';\n"
            "    exportBtn.addEventListener('click', () => {\n"
            "      let url = window.location.origin + '/api/" store-name "?limit=100000&offset=0';\n"
            "      if (_sort['" store-name "']) url += '&sort=' + _sort['" store-name "'] + '&dir=' + (_sortDir['" store-name "'] || 'asc');\n"
            "      if (_search['" store-name "']) url += '&search=' + encodeURIComponent(_search['" store-name "']);\n"
            "      fetch(url).then(r => r.json()).then(rows => {\n"
            "        if (rows.length === 0) return;\n"
            "        const headers = Object.keys(rows[0]);\n"
            "        const _csvQ = v => '\"' + String(v).replace(/\"/g, '\"\"') + '\"';\n"
            "        const csv = headers.join(',') + '\\n' + rows.map(r => headers.map(h => _csvQ(r[h] || '')).join(',')).join('\\n');\n"
            "        const blob = new Blob([csv], { type: 'text/csv' });\n"
            "        const a = document.createElement('a');\n"
            "        a.href = URL.createObjectURL(blob);\n"
            "        a.download = '" store-name ".csv';\n"
            "        a.click();\n"
            "      });\n"
            "    });\n"
            "    toolbar.appendChild(exportBtn);\n")
          "")

        selection-setup (if is-server
          (str
            "    const _selected = new Set();\n"
            "    const _selectBar = document.createElement('div');\n"
            "    _selectBar.className = 'flex items-center justify-between px-4 py-2 border-t border-border bg-muted/50';\n"
            "    _selectBar.style.display = 'none';\n"
            "    const _selectCount = document.createElement('span');\n"
            "    _selectCount.className = 'text-sm text-muted-foreground';\n"
            "    const _exportSelBtn = document.createElement('button');\n"
            "    _exportSelBtn.textContent = 'Export Selected';\n"
            "    _exportSelBtn.className = 'px-3 py-1 text-sm font-medium border border-border text-foreground rounded-md hover:bg-muted';\n"
            "    _exportSelBtn.addEventListener('click', () => {\n"
            "      if (_selected.size === 0) return;\n"
            "      const rows = Array.from(_selected).map(eid => " store-name ".get(eid)).filter(Boolean);\n"
            "      if (rows.length === 0) return;\n"
            "      const headers = Object.keys(rows[0]);\n"
            "      const _csvQ = v => '\"' + String(v).replace(/\"/g, '\"\"') + '\"';\n"
            "      const csv = headers.join(',') + '\\n' + rows.map(r => headers.map(h => _csvQ(r[h] || '')).join(',')).join('\\n');\n"
            "      const blob = new Blob([csv], { type: 'text/csv' });\n"
            "      const a = document.createElement('a');\n"
            "      a.href = URL.createObjectURL(blob);\n"
            "      a.download = '" store-name "_selected.csv';\n"
            "      a.click();\n"
            "    });\n"
            "    _selectBar.appendChild(_selectCount);\n"
            "    _selectBar.appendChild(_exportSelBtn);\n"
            "    function _updateSelectBar() {\n"
            "      _selectBar.style.display = _selected.size > 0 ? '' : 'none';\n"
            "      _selectCount.textContent = _selected.size + ' selected';\n"
