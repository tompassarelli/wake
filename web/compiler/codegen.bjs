            col-children) ""))

        view-open #r#"
  (function() {
    const viewEl = document.createElement('div');
    viewEl.className = 'view-card';

    const toolbar = document.createElement('div');
    toolbar.className = 'flex items-center justify-between px-4 py-3 border-b border-border';
    const titleEl = document.createElement('h1');
    titleEl.className = 'text-lg font-semibold text-foreground';
"#

        add-toggle-js #r#"
    const addToggle = document.createElement('button');
    addToggle.textContent = '+ Add';
    addToggle.className = 'px-3 py-1 text-sm font-medium bg-primary text-primary-foreground rounded-md hover:opacity-90';
    toolbar.appendChild(addToggle);
"#

        form-chrome #r#"
    const formEl = document.createElement('form');
    formEl.className = 'flex flex-col gap-3 p-4 border-b border-border';
    formEl.style.display = 'none';
"#

        form-actions #r#"
    const formActions = document.createElement('div');
    formActions.className = 'flex gap-2';
    const submitBtn = document.createElement('button');
    submitBtn.type = 'submit';
    submitBtn.className = 'px-4 py-2 bg-primary text-primary-foreground rounded-md text-sm font-medium hover:opacity-90';
    submitBtn.textContent = 'Add';
    formActions.appendChild(submitBtn);
    const cancelBtn = document.createElement('button');
    cancelBtn.type = 'button';
    cancelBtn.className = 'px-4 py-2 border border-border rounded-md text-sm font-medium text-muted-foreground hover:bg-muted';
    cancelBtn.textContent = 'Cancel';
    cancelBtn.addEventListener('click', () => { formEl.style.display = 'none'; addToggle.style.display = ''; });
    formActions.appendChild(cancelBtn);
    formEl.appendChild(formActions);
    addToggle.addEventListener('click', () => { formEl.style.display = ''; addToggle.style.display = 'none'; });
    formEl.addEventListener('submit', (e) => {
      e.preventDefault();
"#

        form-submit-tail #r#"
      formEl.style.display = 'none';
      addToggle.style.display = '';
    });
    viewEl.appendChild(formEl);

"#

        filter-dropdowns-js (if has-filters
          (.join (mapv (fn [f]
            (let [fname (.-name f)
                  fltable (.-filter-lookup-table f)
                  ltable (or fltable (.-lookup-table f))
                  is-lookup (not (nil? ltable))
                  label (titlecase fname)
                  fetch-url (if is-lookup
                    (str "/api/_lookup/" ltable)
                    (str "/api/_distinct/" store-name "/" fname))
                  option-builder (if is-lookup
                    (str "      rows.forEach(r => { const o = document.createElement('option'); o.value = r.id; o.textContent = r.name; _fsel_" fname ".appendChild(o); });\n")
                    (str "      rows.forEach(v => { const o = document.createElement('option'); o.value = v; o.textContent = v; _fsel_" fname ".appendChild(o); });\n"))]
              (str "    const _fsel_" fname " = document.createElement('select');\n"
                   "    _fsel_" fname ".className = 'px-2 py-1.5 border border-border rounded-md bg-background text-foreground text-xs';\n"
                   "    _fsel_" fname ".innerHTML = '<option value=\"\">All " label "</option>';\n"
                   "    fetch(window.location.origin + '" fetch-url "').then(r => r.json()).then(rows => {\n"
                   option-builder
                   "    });\n"
                   "    _fsel_" fname ".addEventListener('change', () => {\n"
                   "      if (!_filters['" store-name "']) _filters['" store-name "'] = {};\n"
                   "      _filters['" store-name "']['" fname "'] = _fsel_" fname ".value;\n"
                   "      _page['" store-name "'] = 0;\n"
                   "      loadStore('" store-name "');\n"
                   "    });\n")))
            filter-fields-meta) "")
          "")

        date-filter-inputs-js (if has-date-filters
          (.join (mapv (fn [f]
            (let [fname (.-name f)
                  label (titlecase fname)]
              (str "    const _dflabel_" fname " = document.createElement('span');\n"
                   "    _dflabel_" fname ".textContent = '" label ":';\n"
                   "    _dflabel_" fname ".className = 'text-xs text-muted-foreground self-center';\n"
                   "    const _dfrom_" fname " = document.createElement('input');\n"
                   "    _dfrom_" fname ".type = 'date';\n"
                   "    _dfrom_" fname ".className = 'px-2 py-1 border border-border rounded-md bg-background text-foreground text-xs';\n"
                   "    _dfrom_" fname ".title = '" label " from';\n"
                   "    const _dto_" fname " = document.createElement('input');\n"
                   "    _dto_" fname ".type = 'date';\n"
                   "    _dto_" fname ".className = 'px-2 py-1 border border-border rounded-md bg-background text-foreground text-xs';\n"
                   "    _dto_" fname ".title = '" label " to';\n"
                   "    _dfrom_" fname ".addEventListener('change', () => {\n"
                   "      if (!_filters['" store-name "']) _filters['" store-name "'] = {};\n"
                   "      _filters['" store-name "']['" fname "_from'] = _dfrom_" fname ".value;\n"
                   "      _page['" store-name "'] = 0;\n"
