          "")

        select-all-cb (if is-server
          (str
            "    const _selectAll = document.createElement('input');\n"
            "    _selectAll.type = 'checkbox';\n"
            "    _selectAll.className = 'w-4 h-4 cursor-pointer self-center';\n"
            "    _selectAll.addEventListener('change', () => {\n"
            "      for (const [eid, inst] of instances) {\n"
            "        const cb = inst.el.querySelector('input[type=\"checkbox\"]');\n"
            "        if (cb) cb.checked = _selectAll.checked;\n"
            "        if (_selectAll.checked) _selected.add(eid);\n"
            "        else _selected.delete(eid);\n"
