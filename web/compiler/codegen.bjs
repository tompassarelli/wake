        search-setup (str #r#"
    const searchEl = document.createElement('input');
    searchEl.type = 'text';
    searchEl.placeholder = 'Search...';
    searchEl.className = 'w-full px-3 py-2 border border-border rounded-md bg-background text-foreground text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring';
    const statsEl = document.createElement('div');
    statsEl.className = 'mt-2 text-xs text-muted-foreground';
    const searchBar = document.createElement('div');
    searchBar.className = 'p-4 border-b border-border';
    searchBar.appendChild(searchEl);

"#
          filter-dropdowns-js
          date-filter-inputs-js
          saved-search-js
          filter-bar-append-js
          #r#"
    searchBar.appendChild(statsEl);
    const listEl = document.createElement('div');
    listEl.className = 'flex-1 overflow-y-auto';

"#
          (if is-server
            (str "    function filterRows() {}\n"
                 "    let _searchTimer = null;\n"
                 "    searchEl.addEventListener('input', () => {\n"
                 "      clearTimeout(_searchTimer);\n"
                 "      _searchTimer = setTimeout(() => {\n"
                 "        _search['" store-name "'] = searchEl.value.trim();\n"
                 "        _page['" store-name "'] = 0;\n"
                 "        loadStore('" store-name "');\n"
                 "      }, 300);\n"
                 "    });\n")
            (str "    function filterRows() {\n"
                 "      const q = searchEl.value.toLowerCase();\n"
                 "      let visible = 0;\n"
                 "      for (const [eid, inst] of instances) {\n")))

        filter-fn-bottom (if is-server ""
          #r#"
        if (!entity) continue;
        const text = Object.values(entity).join(' ').toLowerCase();
        const show = !q || text.includes(q);
        inst.el.hidden = !show;
        if (show) visible++;
      }
      statsEl.textContent = q ? visible + ' of ' + instances.size : 'Total: ' + instances.size;
    }
    searchEl.addEventListener('input', filterRows);

"#
        )

        split-pane-setup (str
          "    viewEl.appendChild(searchBar);\n"
          "    const splitPane = document.createElement('div');\n"
          "    splitPane.className = 'flex flex-1 min-h-0';\n"
          "    const leftPane = document.createElement('div');\n"
          "    leftPane.className = 'flex flex-col w-1/2 min-h-0 border-r border-border';\n"
          "    leftPane.appendChild(colHeader);\n"
          "    leftPane.appendChild(listEl);\n"
          "    splitPane.appendChild(leftPane);\n"
          "    const rightPane = document.createElement('div');\n"
          "    rightPane.className = 'w-1/2 min-h-0 overflow-y-auto';\n"
          "    const detailEmpty = document.createElement('div');\n"
          "    detailEmpty.className = 'flex items-center justify-center h-full text-muted-foreground text-sm';\n"
          "    detailEmpty.textContent = 'Select an item to view details';\n"
          "    rightPane.appendChild(detailEmpty);\n"
          "    splitPane.appendChild(rightPane);\n"
          "    viewEl.appendChild(splitPane);\n\n"
          "    let selectedEid = null;\n"
          "    let detailInst = null;\n"
          "    let selectedRowEl = null;\n"
          "    let _tabBarEl = null;\n"
          "    let _tabContentEl = null;\n"
          "    function selectItem(eid) {\n"
          "      if (selectedRowEl) selectedRowEl.classList.remove('bg-muted');\n"
          "      selectedEid = eid;\n"
          "      if (detailInst) { detailInst.destroy(); detailInst = null; }\n"
          "      if (_tabBarEl) { _tabBarEl.remove(); _tabBarEl = null; }\n"
          "      if (_tabContentEl) { _tabContentEl.remove(); _tabContentEl = null; }\n"
          "      if (eid === null) { detailEmpty.style.display = ''; selectedRowEl = null; return; }\n"
          "      detailEmpty.style.display = 'none';\n")

        inline-edit-all (str
          "      rightPane.appendChild(detailInst.el);\n"
          lookup-map-js
          nav-map-js
          "      for (const [attr, node] of Object.entries(detailInst.nodes)) {\n"
          (if (not (= nav-map-js ""))
            (str
              "        if (_navFields && _navFields[attr]) {\n"
              "          const _ni = document.createElement('span');\n"
              "          _ni.textContent = ' \\u2192';\n"
              "          _ni.className = 'text-primary cursor-pointer text-xs inline-block';\n"
              "          _ni.title = 'Go to ' + attr;\n"
              "          _ni.addEventListener('click', (e) => {\n"
              "            e.stopPropagation();\n"
              "            navigate(_navFields[attr]);\n"
              "          });\n"
              "          if (node.parentNode) node.parentNode.insertBefore(_ni, node.nextSibling);\n"
              "        }\n")
            "")
          "        node.style.cursor = 'pointer';\n"
          "        node.addEventListener('click', () => {\n"
          (if (some? lookup-fields-meta)
            (str
              "          if (_lookups && _lookups[attr]) {\n"
              "            const _sel = document.createElement('select');\n"
              "            _sel.className = 'px-3 py-2 border border-input rounded-md bg-background text-foreground text-sm w-full';\n"
              "            node.replaceWith(_sel);\n"
              "            const _eo = document.createElement('option');\n"
              "            _eo.value = '';\n"
              "            _eo.textContent = '\\u2014 select \\u2014';\n"
              "            _sel.appendChild(_eo);\n"
              "            fetch(window.location.origin + '/api/_lookup/' + _lookups[attr])\n"
              "              .then(r => r.json())\n"
              "              .then(opts => {\n"
              "                const _cur = node.textContent;\n"
              "                opts.forEach(o => {\n"
              "                  const _o = document.createElement('option');\n"
              "                  _o.value = o.id;\n"
              "                  _o.textContent = o.name;\n"
              "                  if (o.name === _cur) _o.selected = true;\n"
              "                  _sel.appendChild(_o);\n"
              "                });\n"
              "                _sel.focus();\n"
              "              });\n"
              "            let _ld = false;\n"
              "            const _lc = () => {\n"
              "              if (_ld) return;\n"
              "              _ld = true;\n"
              "              const _so = _sel.options[_sel.selectedIndex];\n"
              "              if (_so && _so.value) {\n"
              "                node.textContent = _so.textContent;\n"
              "                fetch(window.location.origin + '/api/" store-name "/' + selectedEid, {\n"
              "                  method: 'PUT',\n"
              "                  headers: { 'Content-Type': 'application/json' },\n"
              "                  body: JSON.stringify({ [attr]: _so.value })\n"
              "                });\n"
              "                const _ent = " store-name ".get(selectedEid);\n"
              "                if (_ent) _ent[attr] = _so.textContent;\n"
              "              }\n"
              "              _sel.replaceWith(node);\n"
              "            };\n"
              "            _sel.addEventListener('blur', () => setTimeout(_lc, 150));\n"
              "            _sel.addEventListener('change', _lc);\n"
              "            _sel.addEventListener('keydown', (e) => {\n"
              "              if (e.key === 'Escape') { _ld = true; _sel.replaceWith(node); }\n"
              "            });\n"
              "          } else {\n")
            "")
          "          const input = document.createElement('input');\n"
          "          input.value = " store-name ".get(selectedEid)?.[attr] || '';\n"
          "          input.className = 'px-3 py-2 border border-input rounded-md bg-background text-foreground text-sm w-full';\n"
          "          node.replaceWith(input);\n"
          "          input.focus();\n"
          "          input.select();\n"
          "          let done = false;\n"
          "          const commit = () => {\n"
          "            if (done) return;\n"
          "            done = true;\n"
          "            input.replaceWith(node);\n"
          "            " store-name ".update(selectedEid, attr, input.value.trim());\n"
          "          };\n"
          "          input.addEventListener('blur', commit);\n"
          "          input.addEventListener('keydown', (e) => {\n"
          "            if (e.key === 'Enter') { e.preventDefault(); commit(); }\n"
          "            if (e.key === 'Escape') { done = true; input.replaceWith(node); }\n"
          "          });\n"
          (if (some? lookup-fields-meta) "          }\n" "")
          "        });\n"
          "      }\n")

        select-item-close #r#"
      const inst = instances.get(eid);
      if (inst) { inst.el.classList.add('bg-muted'); selectedRowEl = inst.el; }
    }

"#

        no-select-layout #r#"
    viewEl.appendChild(searchBar);
    viewEl.appendChild(colHeader);
    viewEl.appendChild(listEl);

"#

        watcher-add #r#"
    const instances = new Map();
"#

        watcher-add-tail (str
          "        inst.el.className = (inst.el.className || '') + ' cursor-pointer hover:bg-muted/50 transition-colors';\n"
          "        inst.el.style.display = 'grid';\n"
          "        inst.el.style.gridTemplateColumns = '" grid-tpl-sel "';\n"
          "        for (const ch of inst.el.children) { ch.style.width = 'auto'; ch.style.minWidth = '0'; }\n")

        watcher-update #r#"
        listEl.appendChild(inst.el);
        instances.set(evt.eid, inst);
        filterRows();
      }
      if (evt.type === 'update') {
        const inst = instances.get(evt.eid);
        if (inst && inst.update[evt.attr]) inst.update[evt.attr](evt.new || '');
"#

        watcher-remove #r#"
      }
      if (evt.type === 'remove') {
        const inst = instances.get(evt.eid);
        if (inst) { inst.destroy(); instances.delete(evt.eid); }
        filterRows();
"#

        watcher-load #r#"
      }
      if (evt.type === 'load') {
        listEl.innerHTML = '';
        instances.clear();
"#

        watcher-load-body (str
          "          inst.el.className = (inst.el.className || '') + ' cursor-pointer hover:bg-muted/50 transition-colors';\n"
          "          inst.el.style.display = 'grid';\n"
          "          inst.el.style.gridTemplateColumns = '" grid-tpl-sel "';\n"
          "          for (const ch of inst.el.children) { ch.style.width = 'auto'; ch.style.minWidth = '0'; }\n")

        watcher-load-tail #r#"
          listEl.appendChild(inst.el);
          instances.set(entity.eid, inst);
        }
        filterRows();
      }
    });

"#

        pagination-bar (str #r#"
    const pageBar = document.createElement('div');
    pageBar.className = 'flex items-center justify-between px-4 py-2 border-t border-border text-xs text-muted-foreground';
    const pageInfo = document.createElement('span');
    const pageNav = document.createElement('div');
    pageNav.className = 'flex gap-2';
    const prevBtn = document.createElement('button');
    prevBtn.textContent = '← Prev';
    prevBtn.className = 'px-2 py-1 border border-border rounded-md hover:bg-muted';
    const nextBtn = document.createElement('button');
    nextBtn.textContent = 'Next →';
    nextBtn.className = 'px-2 py-1 border border-border rounded-md hover:bg-muted';
    pageNav.appendChild(prevBtn);
    pageNav.appendChild(nextBtn);
    pageBar.appendChild(pageInfo);
    pageBar.appendChild(pageNav);
"#
          "\n    function updatePageInfo() {\n"
          "      const p = _page['" store-name "'] || 0;\n"
          "      const total = _totals['" store-name "'] || 0;\n"
          "      const pages = Math.ceil(total / _pageSize);\n"
          "      pageInfo.textContent = 'Page ' + (p + 1) + ' of ' + (pages || 1) + ' (' + total + ' total)';\n"
          "      prevBtn.disabled = p <= 0;\n"
          "      nextBtn.disabled = p >= pages - 1;\n"
          "    }\n"
          "    prevBtn.addEventListener('click', () => { _page['" store-name "'] = Math.max(0, (_page['" store-name "'] || 0) - 1); loadStore('" store-name "'); });\n"
          "    nextBtn.addEventListener('click', () => { _page['" store-name "'] = (_page['" store-name "'] || 0) + 1; loadStore('" store-name "'); });\n"
          "    onPageChange(updatePageInfo);\n")

        view-close #r#"
  })();
"#
      ]
    (str
      "  // ── View: " view-name " ──\n"
      view-open
      "    titleEl.textContent = " (q title) ";\n"
      "    toolbar.appendChild(titleEl);\n"
      (if has-form (str add-toggle-js) "")
      export-btn-js
      "    viewEl.appendChild(toolbar);\n"

      ;; Collapsible form
      (if has-form
        (str form-chrome form-fields form-actions
          "      const first = form_" (id->ref (nth add-fields 0)) ".value.trim();\n"
          "      if (!first) return;\n"
          "      " store-name ".add({ " add-obj " });\n"
          clear-lines "\n"
          form-submit-tail)
        "")

      ;; Search + filter
      search-setup
      (if (not is-server) (str "        const entity = " store-name ".get(eid);\n") "")
      filter-fn-bottom

      ;; Column header
      col-header-js
      select-all-cb

      ;; Layout: split pane or stacked
      (if has-select
        (str split-pane-setup
          "      const entity = " store-name ".get(eid);\n"
          "      if (!entity) return;\n"
          "      detailInst = " select-fn-name "(entity);\n"
          inline-edit-all
          tab-code
          select-item-close)
        no-select-layout)

      ;; Store watcher
      selection-setup
      watcher-add
      "    " store-name ".watch((evt) => {\n"
      "      if (evt.type === 'add') {\n"
      "        const inst = " fn-name "(evt.entity);\n"
      watcher-add-tail
      row-cb-add
      (if has-select "        inst.el.addEventListener('click', () => selectItem(evt.eid));\n" "")
      watcher-update
      (if has-select "        if (selectedEid === evt.eid && detailInst && detailInst.update[evt.attr]) detailInst.update[evt.attr](evt.new || '');\n" "")
      watcher-remove
      (if has-select "        if (selectedEid === evt.eid) selectItem(null);\n" "")
      (if is-server "        _selected.delete(evt.eid); _updateSelectBar();\n" "")
      watcher-load
      (if has-select "        if (selectedEid) selectItem(null);\n" "")
      (if is-server "        _selected.clear(); _updateSelectBar();\n        if (_selectAll) _selectAll.checked = false;\n" "")
      "        for (const entity of " store-name ".all()) {\n"
      "          const inst = " fn-name "(entity);\n"
      watcher-load-body
      row-cb-load
      (if has-select "          inst.el.addEventListener('click', () => selectItem(entity.eid));\n" "")
      watcher-load-tail

      (if is-server
        (str pagination-bar
          (if has-select
            (str "    leftPane.appendChild(pageBar);\n"
                 "    leftPane.appendChild(_selectBar);\n")
            (str "    viewEl.appendChild(pageBar);\n"
                 "    viewEl.appendChild(_selectBar);\n")))
        "")

      "    viewContainers[" (q view-name) "] = viewEl;\n"
      "    main.appendChild(viewEl);\n"
      view-close)))

(defn gen-routed-program [(prog :- Any)] :- String
  (let [g (graph/check-program prog)
        components (or (.-components prog) [])
        views (or (.-views prog) [])
        router (.-router prog)
        panels (or (.-panels prog) [])
        routes (.-routes router)
        default-route (.-default-route router)
        persist (.-persist g)
        persist-key (if (nil? persist) nil (.-key persist))
        persist-mode (if (nil? persist) nil (.-storage persist))
        is-server (= persist-mode "server")
        src-name (.-ns g)
        layout (.-layout g)
        layout-title (if (and (some? layout) (some? (.-title layout)))
                       (.-title layout)
                       (titlecase src-name))
        nav-groups (if (and (some? layout) (> (count (.-groups layout)) 0))
                     (.-groups layout)
                     nil)

        unique-entities (reduce
          (fn [acc v]
            (let [en (.-entity-name v)]
              (if (some? (first (filterv (fn [e] (= (.-name e) en)) acc)))
                acc
                (let [ge (first (filterv (fn [e] (= (.-name e) en)) (.-entities g)))]
                  (conj acc ge)))))
          [] views)
        all-stores (mapv (fn [e] (.-store-name e)) unique-entities)

        unique-comp-names (reduce
          (fn [acc v]
            (let [names (filterv some? [(.-component v) (.-select-component v)])]
              (reduce (fn [a n] (if (.includes a n) a (conj a n))) acc names)))
          [] views)

        gen-nav-btn (fn [vname]
          (let [v (first (filterv (fn [vi] (= (.-name vi) vname)) views))
                label (if (some? v) (or (.-title v) (titlecase vname)) (titlecase vname))]
            (str "    const nav_" (id->ref vname) " = document.createElement('button');\n"
                 "    nav_" (id->ref vname) ".className = 'sidebar-item';\n"
                 "    nav_" (id->ref vname) ".textContent = " (q label) ";\n"
                 "    nav_" (id->ref vname) ".addEventListener('click', () => navigate(" (q vname) "));\n"
                 "    sidebarContent.appendChild(nav_" (id->ref vname) ");\n"
                 "    navButtons[" (q vname) "] = nav_" (id->ref vname) ";\n")))

        nav-buttons (if (some? nav-groups)
          (.join
            (mapv (fn [grp]
              (str "    const grpLabel_" (id->ref (.-label grp)) " = document.createElement('div');\n"
                   "    grpLabel_" (id->ref (.-label grp)) ".className = 'sidebar-group-label';\n"
                   "    grpLabel_" (id->ref (.-label grp)) ".textContent = " (q (.-label grp)) ";\n"
                   "    sidebarContent.appendChild(grpLabel_" (id->ref (.-label grp)) ");\n"
                   (.join (mapv gen-nav-btn (.-items grp)) "\n")))
              nav-groups) "\n")
          (.join
            (mapv (fn [r] (gen-nav-btn (.-view-name r))) routes) "\n"))

        view-sections (.join
          (mapv (fn [v]
            (let [en (.-entity-name v)
                  ge (first (filterv (fn [e] (= (.-name e) en)) (.-entities g)))
                  store-name (.-store-name ge)]
              (gen-view-section v components ge store-name is-server (.-entities g) views)))
            views) "\n")

        undo-watchers (.join
          (mapv (fn [sn]
            (let [save (cond is-server (str "    syncToServer('" sn "', evt);\n")
                             (not (nil? persist-key)) "    saveDb();\n"
                             :else "")]
              (str sn ".watch((evt) => {\n"
                   "  if (evt.type === 'add') {\n"
                   "    recordUndo({ type: 'add', store: " sn ", eid: evt.eid, entity: evt.entity });\n"
                   save
                   "  }\n"
                   "  if (evt.type === 'update') {\n"
                   "    recordUndo({ type: 'update', store: " sn ", eid: evt.eid, attr: evt.attr, old: evt.old, 'new': evt.new });\n"
                   save
                   "  }\n"
                   "  if (evt.type === 'remove') {\n"
                   "    recordUndo({ type: 'remove', store: " sn ", eid: evt.eid, entity: evt.entity });\n"
                   save
                   "  }\n"
                   "});\n")))
            all-stores) "\n")

        navigate-fn #r#"
  let currentView = '';
  function navigate(name) {
    for (const [n, el] of Object.entries(viewContainers)) {
      el.style.display = n !== name ? 'none' : '';
    }
    currentView = name;
    location.hash = '#' + name;
    for (const [n, btn] of Object.entries(navButtons)) {
      btn.classList.toggle('active', n === name);
    }
  }
"#
]

    (str
      "// Generated by wake — semantic UI compiler\n"
      "// Source: " src-name "\n"
      "// This file is a build artifact. Edit the .wake source, not this file.\n\n"
      "(function() {\n"
      "'use strict';\n\n"

      ;; Inlined value-equality runtime (backs the store change-gate).
      (gen-equiv-runtime) "\n"

      "// ── Stores ────────────────────────────────────────\n"
      (.join (mapv (fn [e] (gen-store (.-store-name e) [])) unique-entities) "\n\n")
      "\n\n"

      "// ── Components ──────────────────────────────────────\n"
      (.join
        (mapv (fn [cn]
          (gen-component-fn! (first (filterv (fn [c] (= (.-name c) cn)) components)) ""))
          unique-comp-names) "\n")
      "\n"

      "// ── Undo / Redo ─────────────────────────────────────\n"
      (gen-undo-redo) "\n"

      (cond
        (not (nil? persist-key))
          (str "// ── Persistence ──────────────────────────────────────\n"
               (gen-persistence persist-key all-stores) "\n")
        :else "")

      "// ── Undo watchers ───────────────────────────────────\n"
      undo-watchers "\n"

      "// ── Init ─────────────────────────────────────────────\n"
      (if is-server "async function init() {\n" "function init() {\n")
      #r#"
  const root = document.getElementById(window.WAKE_MOUNT_ID || 'app');
  const app = document.createElement('div');
  app.className = 'sidebar-layout';

  const sidebar = document.createElement('aside');
  sidebar.className = 'sidebar';
  const sidebarHeader = document.createElement('div');
  sidebarHeader.className = 'sidebar-header';
  sidebarHeader.textContent =
"#
      " " (q layout-title) ";\n"
      #r#"
  sidebar.appendChild(sidebarHeader);
  const sidebarContent = document.createElement('div');
  sidebarContent.className = 'sidebar-content';
  const navButtons = {};
"#
      "\n" nav-buttons "\n"
      #r#"
  sidebar.appendChild(sidebarContent);

  const sidebarFooter = document.createElement('div');
  sidebarFooter.className = 'sidebar-footer';
  const darkToggle = document.createElement('button');
  darkToggle.className = 'sidebar-item';
  darkToggle.textContent = document.documentElement.classList.contains('dark') ? '☀ Light' : '☾ Dark';
  darkToggle.addEventListener('click', () => {
    document.documentElement.classList.toggle('dark');
    const isDark = document.documentElement.classList.contains('dark');
    darkToggle.textContent = isDark ? '☀ Light' : '☾ Dark';
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
  if (localStorage.getItem('theme') === 'dark') document.documentElement.classList.add('dark');
  darkToggle.textContent = document.documentElement.classList.contains('dark') ? '☀ Light' : '☾ Dark';

  const collapseToggle = document.createElement('button');
  collapseToggle.className = 'sidebar-item';
  collapseToggle.textContent = '« Collapse';
  collapseToggle.addEventListener('click', () => {
    sidebar.classList.toggle('collapsed');
    collapseToggle.textContent = sidebar.classList.contains('collapsed') ? '»' : '« Collapse';
  });
  sidebarFooter.appendChild(darkToggle);
  sidebarFooter.appendChild(collapseToggle);
  sidebar.appendChild(sidebarFooter);

  app.appendChild(sidebar);

  const main = document.createElement('main');
  main.className = 'sidebar-main';
  const viewContainers = {};
"#
      "\n" view-sections "\n\n"
      #r#"
  app.appendChild(main);
  root.appendChild(app);
"#
      (gen-panels-mount panels "main")
      "\n" navigate-fn "\n"
      "  const hash = location.hash.slice(1) || " (q default-route) ";\n"
      #r#"
  navigate(hash);
  window.addEventListener('hashchange', () => {
    const h = location.hash.slice(1);
    if (h && viewContainers[h]) navigate(h);
  });

  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'z' && !e.shiftKey) { e.preventDefault(); undo(); }
    if ((e.ctrlKey || e.metaKey) && e.key === 'z' && e.shiftKey) { e.preventDefault(); redo(); }
  });

"#
      (cond is-server "  await loadFromServer();\n"
            (not (nil? persist-key)) "  restoreDb();\n"
            :else "")
      "}\n\n"
      "init();\n"
      "})();\n")))

;; --- Main entry point ---

(defn gen-program! [(prog :- Any)] :- String
  (if (and (not (nil? (.-views prog))) (> (count (.-views prog)) 0))
    (if (not (nil? (.-router prog)))
      (gen-routed-program prog)
      (gen-view-program! prog))
  (let [;; Build checked entity graph
        g (graph/check-program prog)

        ;; Expand list-detail into UI graph
        ld (first (.-list-details g))
        sf (first (.-forms g))
        ug (ui/expand-list-detail g ld sf)

        ;; Read from UI graph — no CRM-specific derivation here
        en (.-entity ug)
        store-name (.-store-name ug)
        columns (.-columns ug)
        search-cols (.-search-cols ug)
        overview-fields (.-overview-fields ug)
        title (.-title ug)
        related-info (.-related ug)
        related-tab-keys (mapv (fn [ri] (.-key ri)) related-info)

        derived-attrs (.-derived ug)

        ;; Persist
        persist (.-persist ug)
        persist-key (if (nil? persist) nil (.-key persist))
        persist-mode (if (nil? persist) nil (.-storage persist))
        is-server (= persist-mode "server")
        all-stores (into [store-name] (mapv (fn [ri] (.-store ri)) related-info))

        subtitle-field (if (> (count overview-fields) 1) (nth overview-fields 1) nil)

        layout-result (gen-layout en (.-form ug) title)

        src-name (.-ns g)]

    (str
      "// Generated by wake — semantic UI compiler\n"
      "// Source: " src-name "\n"
      "// This file is a build artifact. Edit the .wake source, not this file.\n\n"
      "(function() {\n"
      "'use strict';\n\n"

      ;; Inlined value-equality runtime (backs the store change-gate).
      (gen-equiv-runtime) "\n"

      ;; Stores
      "// ── Stores ─────────────────────────────────────────\n"
      (gen-store store-name []) "\n"
      "\n"
      (.join
        (mapv (fn [ri]
          (gen-store (.-store ri) [(.-fk-field ri)]))
          related-info)
        "\n")

      ;; Ref declarations
      "\n// ── DOM refs ──────────────────────────────────────\n"
      (gen-ref-decls (.-refs layout-result)) "\n\n"

      ;; Detail panel
      "// ── Detail panel ────────────────────────────────────\n"
      (gen-detail en store-name overview-fields derived-attrs related-info (.-all-field-info ug)) "\n"

      ;; List view
      "\n// ── List view ──────────────────────────────────────\n"
      (gen-list-fns en store-name columns search-cols derived-attrs) "\n"

      ;; Stats
      "\n// ── Stats ────────────────────────────────────────────\n"
      (gen-stats en store-name) "\n"

      ;; Form
      "\n// ── Form ─────────────────────────────────────────────\n"
      (gen-form-handler en (.-form ug)) "\n"

      ;; Persistence
      (cond
        (not (nil? persist-key))
          (str "\n// ── Persistence ──────────────────────────────────────\n"
               (gen-persistence persist-key all-stores) "\n")
        :else "")

      ;; Compiled update paths
      "\n// ── Compiled update paths ────────────────────────────\n"
      (gen-update-fns columns search-cols overview-fields subtitle-field
                      persist-key related-tab-keys derived-attrs store-name is-server) "\n"

      ;; Undo/redo
      "\n// ── Undo / Redo ─────────────────────────────────────\n"
      (gen-undo-redo) "\n"

      ;; Init
      "// ── Init ─────────────────────────────────────────────\n"
      (gen-init-fn en (.-name (.-form ug)) store-name related-info persist-key is-server layout-result) "\n"

      "init();\n"
      "})();\n"))))

