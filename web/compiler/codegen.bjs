                   "    });\n"
                   "    _dto_" fname ".addEventListener('change', () => {\n"
                   "      if (!_filters['" store-name "']) _filters['" store-name "'] = {};\n"
                   "      _filters['" store-name "']['" fname "_to'] = _dto_" fname ".value;\n"
                   "      _page['" store-name "'] = 0;\n"
                   "      loadStore('" store-name "');\n"
                   "    });\n")))
            date-filter-fields-meta) "")
          "")

        saved-search-js (if is-server
          (str "    const _ssKey = 'wake_searches_" store-name "';\n"
               "    const _ssLoad = document.createElement('select');\n"
               "    _ssLoad.className = 'px-2 py-1.5 border border-border rounded-md bg-background text-foreground text-xs';\n"
               "    _ssLoad.innerHTML = '<option value=\"\">Saved Searches</option>';\n"
               "    function _ssRefresh() {\n"
               "      const saved = JSON.parse(localStorage.getItem(_ssKey) || '[]');\n"
               "      _ssLoad.innerHTML = '<option value=\"\">Saved Searches</option>';\n"
               "      saved.forEach((s,i) => { const o = document.createElement('option'); o.value = i; o.textContent = s.name; _ssLoad.appendChild(o); });\n"
               "    }\n"
               "    _ssRefresh();\n"
               "    _ssLoad.addEventListener('change', () => {\n"
               "      const saved = JSON.parse(localStorage.getItem(_ssKey) || '[]');\n"
               "      const idx = parseInt(_ssLoad.value);\n"
               "      if (isNaN(idx)) return;\n"
               "      const s = saved[idx];\n"
               "      if (!s) return;\n"
               "      searchEl.value = s.search || '';\n"
               "      _search['" store-name "'] = s.search || '';\n"
               "      _filters['" store-name "'] = Object.assign({}, s.filters || {});\n"
               "      const sf = s.filters || {};\n"
               (if has-filters
                 (.join (mapv (fn [f] (str "      if (_fsel_" (.-name f) ") _fsel_" (.-name f) ".value = sf['" (.-name f) "'] || '';\n")) filter-fields-meta) "")
