                          "      if (_dto_" fname ") _dto_" fname ".value = sf['" fname "_to'] || '';\n")))
                   date-filter-fields-meta) "")
                 "")
               "      _page['" store-name "'] = 0;\n"
               "      loadStore('" store-name "');\n"
               "    });\n"
               "    const _ssSave = document.createElement('button');\n"
               "    _ssSave.textContent = 'Save';\n"
               "    _ssSave.className = 'px-2 py-1 text-xs border border-border rounded-md bg-background text-foreground hover:bg-muted';\n"
               "    _ssSave.addEventListener('click', () => {\n"
               "      const name = prompt('Search name:');\n"
               "      if (!name) return;\n"
               "      const saved = JSON.parse(localStorage.getItem(_ssKey) || '[]');\n"
               "      saved.push({ name, search: searchEl.value, filters: Object.assign({}, _filters['" store-name "'] || {}) });\n"
               "      localStorage.setItem(_ssKey, JSON.stringify(saved));\n"
               "      _ssRefresh();\n"
               "    });\n"
               "    const _ssDel = document.createElement('button');\n"
               "    _ssDel.textContent = '✕';\n"
               "    _ssDel.className = 'px-2 py-1 text-xs border border-border rounded-md bg-background text-destructive hover:bg-muted';\n"
               "    _ssDel.addEventListener('click', () => {\n"
               "      const idx = parseInt(_ssLoad.value);\n"
               "      if (isNaN(idx)) return;\n"
               "      const saved = JSON.parse(localStorage.getItem(_ssKey) || '[]');\n"
               "      saved.splice(idx, 1);\n"
               "      localStorage.setItem(_ssKey, JSON.stringify(saved));\n"
               "      _ssRefresh();\n"
               "    });\n")
          "")

        filter-bar-append-js (if (or has-filters has-date-filters is-server)
          (let [filter-appends (if has-filters
                  (.join (mapv (fn [f] (str "    filterBar.appendChild(_fsel_" (.-name f) ");\n")) filter-fields-meta) "")
                  "")
                date-appends (if has-date-filters
