          "")

        col-header-js (str
          "    const colHeader = document.createElement('div');\n"
          "    colHeader.className = 'items-center gap-4 px-4 py-2 border-b border-border bg-muted/30';\n"
          "    colHeader.style.display = 'grid';\n"
          "    colHeader.style.gridTemplateColumns = '" grid-tpl-sel "';\n"
          (if is-server
            (str "    const _sortHeaders = {};\n"
              "    function _updateSortIndicators() {\n"
              "      for (const [p, el] of Object.entries(_sortHeaders)) {\n"
              "        const arrow = _sort['" store-name "'] === p ? (_sortDir['" store-name "'] === 'desc' ? ' ↓' : ' ↑') : '';\n"
              "        el.textContent = el.dataset.label + arrow;\n"
              "      }\n"
              "    }\n")
            "")
          (.join (mapv (fn [ch]
            (let [prop (get (get (.-attrs ch) "text") "prop")
                  ref (id->ref prop)]
              (str "    const hdr_" ref " = document.createElement('span');\n"
                   "    hdr_" ref ".className = 'text-xs font-medium uppercase text-muted-foreground truncate" (if is-server " cursor-pointer" "") "';\n"
                   "    hdr_" ref ".textContent = " (q (titlecase prop)) ";\n"
                   "    hdr_" ref ".dataset.label = " (q (titlecase prop)) ";\n"
                   (if is-server
                     (str "    _sortHeaders['" prop "'] = hdr_" ref ";\n"
                          "    hdr_" ref ".addEventListener('click', () => {\n"
                          "      if (_sort['" store-name "'] === '" prop "') { _sortDir['" store-name "'] = _sortDir['" store-name "'] === 'desc' ? 'asc' : 'desc'; }\n"
                          "      else { _sort['" store-name "'] = '" prop "'; _sortDir['" store-name "'] = 'asc'; }\n"
                          "      _page['" store-name "'] = 0;\n"
                          "      _updateSortIndicators();\n"
